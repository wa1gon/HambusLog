<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HamBusLog.Views.RigRadioEditorWindow"
        Title="Edit Radio"
        Width="980"
        Height="760"
        MinWidth="820"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppForegroundBrush}">
    <Grid RowDefinitions="*,Auto" Margin="14">
        <ScrollViewer Grid.Row="0">
            <Grid ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,Auto,Auto" RowSpacing="10" ColumnSpacing="8">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Radio Tag" VerticalAlignment="Center" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedRigRadioTag}" VerticalAlignment="Center" FontWeight="SemiBold" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Radio Name" VerticalAlignment="Center" />
                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding RigctldRadioName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Watermark="My FT-710" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Executable" VerticalAlignment="Center" />
                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding RigctldExecutable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Watermark="rigctld" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Args Template" VerticalAlignment="Center" />
                <TextBox Grid.Row="3" Grid.Column="1"
                         Text="{Binding RigctldArgumentsTemplate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Watermark="-m {rigNum} -T {host} -t {port}{serialArg} {additionalArgs}" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Additional Args" VerticalAlignment="Center" />
                <TextBox Grid.Row="4" Grid.Column="1"
                         Text="{Binding RigctldAdditionalArguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Watermark="-P RTS -s 38400" />

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Host" VerticalAlignment="Center" />
                <TextBox Grid.Row="5" Grid.Column="1"
                         Text="{Binding RigctldHost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Watermark="127.0.0.1" />

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Port" VerticalAlignment="Center" />
                <NumericUpDown Grid.Row="6" Grid.Column="1"
                               Minimum="1" Maximum="65535"
                               Value="{Binding RigctldPort}"
                               HorizontalAlignment="Left" Width="160" />

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Serial Port" VerticalAlignment="Center" />
                <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <ComboBox ItemsSource="{Binding AvailableSerialPorts}"
                              SelectedItem="{Binding SelectedSerialPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Width="360"
                              IsEditable="True" />
                    <Button Content="Refresh"
                            Click="OnRefreshSerialPortsClicked"
                            Padding="10,6"
                            Background="{DynamicResource AppButtonCautionBrush}"
                            Foreground="{DynamicResource AppButtonForegroundBrush}" />
                </StackPanel>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="Rig List" VerticalAlignment="Center" />
                <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <TextBox Text="{Binding RiglistFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="360" />
                    <Button Content="Browse..."
                            Click="OnBrowseRiglistClicked"
                            Padding="10,6"
                            Background="{DynamicResource AppButtonCautionBrush}"
                            Foreground="{DynamicResource AppButtonForegroundBrush}" />
                    <Button Content="Load"
                            Click="OnLoadRiglistClicked"
                            Padding="10,6"
                            Background="{DynamicResource AppButtonCautionBrush}"
                            Foreground="{DynamicResource AppButtonForegroundBrush}" />
                    <Button Content="Reload"
                            Click="OnCatalogReloadClicked"
                            Padding="10,6"
                            Background="{DynamicResource AppButtonCautionBrush}"
                            Foreground="{DynamicResource AppButtonForegroundBrush}" />
                </StackPanel>

                <TextBlock Grid.Row="9" Grid.Column="0" Text="Search Model" VerticalAlignment="Center" />
                <TextBox Grid.Row="9" Grid.Column="1"
                         Text="{Binding RigCatalog.SearchModelText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Watermark="Type model to filter..."
                         Width="320"
                         HorizontalAlignment="Left" />

                <TextBlock Grid.Row="10" Grid.Column="0" Text="Selected Rig" VerticalAlignment="Center" />
                <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding RigCatalog.SelectedEntry.Model, FallbackValue=No rig selected}" VerticalAlignment="Center" />

                <DataGrid Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="2"
                          ItemsSource="{Binding RigCatalog.FilteredEntries}"
                          SelectedItem="{Binding RigCatalog.SelectedEntry, Mode=TwoWay}"
                          SelectionMode="Extended"
                          SelectionChanged="OnCatalogSelectionChanged"
                          IsReadOnly="True"
                          AutoGenerateColumns="False"
                          CanUserSortColumns="True"
                          GridLinesVisibility="Horizontal"
                          MinHeight="220">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Rig #" Binding="{Binding RigNum}" Width="70" />
                        <DataGridTextColumn Header="Mfg" Binding="{Binding Mfg}" Width="120" />
                        <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="180" />
                        <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="100" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                        <DataGridTextColumn Header="Macro" Binding="{Binding Macro}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Margin="0,8,0,0">
                    <TextBlock Grid.Column="0" Text="rigctld Command:" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding RigCatalog.RigctldCommandLine}"
                             IsReadOnly="True"
                             Margin="8,0,8,0"
                             FontFamily="Monospace" />
                    <Button Grid.Column="2" Content="Copy Command" Click="OnCatalogCopyCommandClicked" Padding="10,6" Background="{DynamicResource AppButtonNormalBrush}" Foreground="{DynamicResource AppButtonForegroundBrush}" />
                </Grid>

                <TextBlock Grid.Row="13" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="{Binding RigCatalog.StatusMessage}"
                           FontStyle="Italic"
                           Foreground="{DynamicResource AppAccentBrush}"
                           Margin="0,8,0,0" />
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="1" Padding="0,10,0,2" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Save Radio"
                        Click="OnSaveClicked"
                        Background="{DynamicResource AppButtonNormalBrush}"
                        Foreground="{DynamicResource AppButtonForegroundBrush}"
                        Padding="14,8"
                        FontWeight="Bold" />
                <Button Content="Cancel"
                        Click="OnCancelClicked"
                        Background="{DynamicResource AppButtonCautionBrush}"
                        Foreground="{DynamicResource AppButtonForegroundBrush}"
                        Padding="14,8" />
            </StackPanel>
        </Border>
    </Grid>
</Window>


