<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HamBusLog.Views.RigRadioEditorWindow"
        Title="Edit Radio"
        Width="980"
        Height="780"
        MinWidth="840"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppForegroundBrush}">
    <Grid RowDefinitions="*,Auto" Margin="14">
        <ScrollViewer Grid.Row="0">
            <Grid ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,Auto,Auto" RowSpacing="10" ColumnSpacing="8">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Radio Name" VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding RigctldRadioName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Watermark="My FT-710" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Command Line" VerticalAlignment="Center" />
                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding RigCatalog.RigctldCommandLine}"
                         IsReadOnly="True"
                         Width="720"
                         HorizontalAlignment="Left"
                         FontFamily="Monospace"
                         Watermark="rigctld -m ... -t ... -T ... -C retry=..." />
                <TextBlock Grid.Row="2" Grid.Column="1"
                           Margin="0,34,0,0"
                           Foreground="{DynamicResource AppMutedForegroundBrush}"
                           FontSize="11"
                           Text="Composed from selected rig, host, port, serial port, and retry count." />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Retry Count" VerticalAlignment="Center" />
                <NumericUpDown Grid.Row="4" Grid.Column="1"
                               Minimum="0" Maximum="300"
                               Value="{Binding RigctldReconnectIntervalSeconds}"
                               HorizontalAlignment="Left" Width="160" />
                <TextBlock Grid.Row="4" Grid.Column="1"
                           Margin="0,34,0,0"
                           Foreground="{DynamicResource AppMutedForegroundBrush}"
                           FontSize="11"
                           Text="Adds '-C retry=&lt;value&gt;' to the composed command." />

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Host" VerticalAlignment="Center" />
                <TextBox Grid.Row="5" Grid.Column="1"
                         Text="{Binding RigctldHost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Width="300"
                          HorizontalAlignment="Left"
                         Watermark="127.0.0.1" />

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Port" VerticalAlignment="Center" />
                <NumericUpDown Grid.Row="6" Grid.Column="1"
                               Minimum="1" Maximum="65535"
                               Value="{Binding RigctldPort}"
                               HorizontalAlignment="Left" Width="160" />

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Resource File" VerticalAlignment="Center" />
                <TextBox Grid.Row="7" Grid.Column="1"
                         Text="{Binding ResourcePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="420"
                         HorizontalAlignment="Left"
                         Watermark="/path/to/resource" />

                <TextBlock Grid.Row="8" Grid.Column="0" Text="Rig List" VerticalAlignment="Center" />
                <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <TextBox Text="{Binding RiglistFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Width="420"
                             HorizontalAlignment="Left"
                             Watermark="/path/to/riglist" />
                    <Button Content="Browse..."
                            Click="OnBrowseRiglistClicked"
                            Padding="10,6"
                            Background="{DynamicResource AppButtonCautionBrush}"
                            Foreground="{DynamicResource AppButtonCautionForegroundBrush}" />
                    <Button Content="Load"
                            Click="OnLoadRiglistClicked"
                            Padding="10,6"
                            Background="{DynamicResource AppButtonCautionBrush}"
                            Foreground="{DynamicResource AppButtonCautionForegroundBrush}" />
                    <Button Content="Reload"
                            Click="OnCatalogReloadClicked"
                            Padding="10,6"
                            Background="{DynamicResource AppButtonCautionBrush}"
                            Foreground="{DynamicResource AppButtonCautionForegroundBrush}" />
                </StackPanel>


                <TextBlock Grid.Row="9" Grid.Column="0" Text="Search Model" VerticalAlignment="Top" />
                <StackPanel Grid.Row="9" Grid.Column="1" Spacing="4" Width="420" HorizontalAlignment="Left">
                    <TextBox Text="{Binding RigCatalog.SearchModelText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Watermark="Type any part of model name..." />
                    <Border BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            Background="{DynamicResource AppPanelBackgroundBrush}"
                            IsVisible="{Binding RigCatalog.HasModelSuggestions}">
                        <ListBox ItemsSource="{Binding RigCatalog.FilteredModelSuggestions}"
                                 SelectionChanged="OnModelSuggestionSelectionChanged"
                                 MaxHeight="140" />
                    </Border>
                </StackPanel>

                <TextBlock Grid.Row="10" Grid.Column="0" Text="Selected Rig" VerticalAlignment="Center" />
                <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding RigCatalog.SelectedRigLabel, FallbackValue=No rig selected}" VerticalAlignment="Center" />

                <DataGrid Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="2"
                          ItemsSource="{Binding RigCatalog.FilteredEntries}"
                          SelectedItem="{Binding RigCatalog.SelectedEntry, Mode=TwoWay}"
                          SelectionMode="Single"
                          SelectionChanged="OnCatalogSelectionChanged"
                          IsReadOnly="True"
                          AutoGenerateColumns="False"
                          CanUserSortColumns="True"
                          GridLinesVisibility="Horizontal"
                          MinHeight="220">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Rig #" Binding="{Binding RigNum}" Width="70" />
                        <DataGridTextColumn Header="Mfg" Binding="{Binding Mfg}" Width="120" />
                        <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="180" />
                        <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="100" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                        <DataGridTextColumn Header="Macro" Binding="{Binding Macro}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2" ColumnDefinitions="Auto,*" ColumnSpacing="8" Margin="0,8,0,0">
                    <Button Grid.Column="0" Content="Copy Command" Click="OnCatalogCopyCommandClicked" Padding="10,6" Background="{DynamicResource AppButtonNormalBrush}" Foreground="{DynamicResource AppButtonNormalForegroundBrush}" />
                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                               FontSize="11"
                               Text="Use Copy Command to paste the generated rigctld invocation elsewhere." />
                </Grid>

                <TextBlock Grid.Row="13" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="{Binding RigCatalog.StatusMessage}"
                           FontStyle="Italic"
                           Foreground="{DynamicResource AppAccentBrush}"
                           Margin="0,8,0,0" />
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="1" Padding="0,10,0,2" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Save Radio"
                        Click="OnSaveClicked"
                        Background="{DynamicResource AppButtonNormalBrush}"
                        Foreground="{DynamicResource AppButtonNormalForegroundBrush}"
                        Padding="14,8"
                        FontWeight="Bold" />
                <Button Content="Cancel"
                        Click="OnCancelClicked"
                        Background="{DynamicResource AppButtonCautionBrush}"
                        Foreground="{DynamicResource AppButtonCautionForegroundBrush}"
                        Padding="14,8" />
            </StackPanel>
        </Border>
    </Grid>
</Window>





