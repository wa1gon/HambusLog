<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HamBusLog.Views.ConfigurationWindow"
        Title="Configuration"
        Width="1020"
        Height="760"
        MinWidth="760"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppForegroundBrush}">
    <Grid RowDefinitions="Auto,*,Auto" Margin="16">

        <!-- ── Active Profile (always visible) ─────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10" Spacing="6" ZIndex="10">
            <TextBlock Text="Configuration" FontSize="22" FontWeight="Bold" />
            <Grid ColumnDefinitions="120,300,Auto" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="Active Profile" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AvailableProfiles}"
                          SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                          Background="{DynamicResource AppPanelBackgroundBrush}"
                          Foreground="{DynamicResource AppForegroundBrush}"
                          MaxDropDownHeight="260"
                          HorizontalAlignment="Stretch">
                    <ComboBox.Styles>
                        <Style Selector="ComboBoxItem">
                            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
                            <Setter Property="Background" Value="{DynamicResource AppPanelBackgroundBrush}" />
                        </Style>
                    </ComboBox.Styles>
                </ComboBox>
                <TextBlock Grid.Column="2"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppMutedForegroundBrush}"
                           Text="{Binding SelectedProfile, StringFormat=Current: {0}}" />
            </Grid>
        </StackPanel>

        <TabControl Grid.Row="1" ZIndex="0">

            <!-- ── Config Tab ───────────────────────────────────── -->
            <TabItem Header="Config">
                <StackPanel Margin="12" Spacing="12">
                    <TextBlock Text="Clone Profile" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock Text="Optionally enter a name below, then click Clone to duplicate the active profile." Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox Text="{Binding NewProfileName}"
                                 Watermark="New name (blank = auto)"
                                 Width="280" />
                        <Button Content="Clone Profile" Click="OnCloneProfileClicked" Padding="12,6" Background="{DynamicResource AppButtonNormalBrush}" Foreground="{DynamicResource AppButtonForegroundBrush}" />
                    </StackPanel>

                    <Separator Margin="0,6,0,0" />

                    <TextBlock Text="ADIF Import Directory" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock Text="Used as the default starting folder when selecting ADIF files to import." Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox Text="{Binding AdifDirectory}"
                                 Watermark="/home/you/logs/adif"
                                 Width="420" />
                        <Button Content="Browse..." Click="OnBrowseAdifDirectoryClicked" Padding="10,6" Background="{DynamicResource AppButtonCautionBrush}" Foreground="{DynamicResource AppButtonForegroundBrush}" />
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- ── Colors Tab ────────────────────────────────────── -->
            <TabItem Header="Colors">
                <StackPanel Margin="12" Spacing="16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Background Color" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                <ColorPicker Name="BgColorPicker" />
                            </Border>
                            <TextBlock Name="BgColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Foreground Color" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                <ColorPicker Name="FgColorPicker" />
                            </Border>
                            <TextBlock Name="FgColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Menu Background" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                <ColorPicker Name="MenuBgColorPicker" />
                            </Border>
                            <TextBlock Name="MenuBgColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Menu Foreground" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                <ColorPicker Name="MenuFgColorPicker" />
                            </Border>
                            <TextBlock Name="MenuFgColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Button: Normal" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                <ColorPicker Name="BtnNormalColorPicker" />
                            </Border>
                            <TextBlock Name="BtnNormalColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Button: Caution" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                <ColorPicker Name="BtnCautionColorPicker" />
                            </Border>
                            <TextBlock Name="BtnCautionColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Button: Danger" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                <ColorPicker Name="BtnDangerColorPicker" />
                            </Border>
                            <TextBlock Name="BtnDangerColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Button Foreground" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                <ColorPicker Name="BtnFgColorPicker" />
                            </Border>
                            <TextBlock Name="BtnFgColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                        </StackPanel>
                    </StackPanel>

                    <Separator Margin="0,2,0,2" />

                    <TextBlock Text="Input Controls" FontWeight="SemiBold" FontSize="14" />

                    <StackPanel Spacing="6">
                        <TextBlock Text="Input Background" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                <ColorPicker Name="InputBgColorPicker" />
                            </Border>
                            <TextBlock Name="InputBgColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Input Foreground" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                <ColorPicker Name="InputFgColorPicker" />
                            </Border>
                            <TextBlock Name="InputFgColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Input Border" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                <ColorPicker Name="InputBorderColorPicker" />
                            </Border>
                            <TextBlock Name="InputBorderColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Input Selection Background" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                <ColorPicker Name="InputSelectionBgColorPicker" />
                            </Border>
                            <TextBlock Name="InputSelectionBgColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Input Selection Foreground" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                <ColorPicker Name="InputSelectionFgColorPicker" />
                            </Border>
                            <TextBlock Name="InputSelectionFgColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                        </StackPanel>
                    </StackPanel>

                    <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="10" Background="{DynamicResource AppPanelBackgroundBrush}" Margin="0,8,0,0">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Live Preview" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource AppForegroundBrush}" />

                            <Border Background="{DynamicResource AppMenuBackgroundBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="8">
                                <TextBlock Text="Menu Preview" Foreground="{DynamicResource AppMenuForegroundBrush}" FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Name="MenuContrastLabel" Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Border Background="{DynamicResource AppButtonNormalBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10,5">
                                    <TextBlock Text="Selected Tab" Foreground="{DynamicResource AppButtonForegroundBrush}" />
                                </Border>
                                <Border Background="{DynamicResource AppHeaderBackgroundBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10,5">
                                    <TextBlock Text="Tab" Foreground="{DynamicResource AppForegroundBrush}" />
                                </Border>
                                <Border Background="{DynamicResource AppPanelBackgroundBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10,5">
                                    <TextBlock Text="Hover Tab" Foreground="{DynamicResource AppForegroundBrush}" />
                                </Border>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Normal" Background="{DynamicResource AppButtonNormalBrush}" Foreground="{DynamicResource AppButtonForegroundBrush}" Padding="12,6" />
                                <Button Content="Caution" Background="{DynamicResource AppButtonCautionBrush}" Foreground="{DynamicResource AppButtonForegroundBrush}" Padding="12,6" />
                                <Button Content="Danger" Background="{DynamicResource AppButtonDangerBrush}" Foreground="{DynamicResource AppButtonForegroundBrush}" Padding="12,6" />
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock Name="ButtonNormalContrastLabel" Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                                <TextBlock Name="ButtonCautionContrastLabel" Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                                <TextBlock Name="ButtonDangerContrastLabel" Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>

            <!-- ── Database Tab ──────────────────────────────────── -->
            <TabItem Header="Database">
                <StackPanel Margin="12" Spacing="12">
                    <TextBlock Text="Database Location (SQLite)" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock Text="Choose a folder and filename. These values are stored in config and used to build the SQLite connection string." Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox Text="{Binding DatabaseFolderPath}"
                                 Watermark="/home/you/.local/share/hambuslog"
                                 Width="520" />
                        <Button Content="Browse Folder..." Click="OnBrowseDatabaseDirectoryClicked" Padding="10,6" Background="{DynamicResource AppButtonCautionBrush}" Foreground="{DynamicResource AppButtonForegroundBrush}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox Text="{Binding DatabaseFileName}"
                                 Watermark="hambuslog.db"
                                 Width="240" />
                        <TextBlock Text="Combined path:" VerticalAlignment="Center" Foreground="{DynamicResource AppMutedForegroundBrush}" />
                        <TextBlock Text="{Binding DatabaseFilePath}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Width="420" />
                    </StackPanel>

                    <Separator Margin="0,2,0,2" />

                    <TextBlock Text="Connection String" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock Text="SQLite example: Data Source=hambuslog.db" Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                    <TextBlock Text="PostgreSQL example: Host=localhost;Database=hamlog;Username=ham;Password=..." Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                    <TextBox Text="{Binding ConnectionString}"
                             Watermark="Data Source=hambuslog.db"
                             AcceptsReturn="False" />
                </StackPanel>
            </TabItem>

            <TabItem Header="Rig Control">
                <Grid Margin="12" RowDefinitions="Auto,Auto,Auto,Auto">
                    <TextBlock Grid.Row="0" Text="rigctld Configuration" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock Grid.Row="1" Text="Manage radios here, then open the editor dialog for detailed rigctld fields." Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" Margin="0,0,0,6" />
                    <Grid Grid.Row="2" ColumnDefinitions="160,*" RowDefinitions="Auto,Auto" RowSpacing="10" ColumnSpacing="8" Margin="0,0,0,12">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Radio" VerticalAlignment="Center" />
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="6">
                            <ComboBox ItemsSource="{Binding AvailableRigRadioOptions}"
                                      SelectedItem="{Binding SelectedRigRadio, Mode=TwoWay}"
                                      DisplayMemberBinding="{Binding Display}"
                                      Background="{DynamicResource AppPanelBackgroundBrush}"
                                      Foreground="{DynamicResource AppForegroundBrush}"
                                      Width="220"
                                      IsEditable="False"
                                      HorizontalAlignment="Left" />
                            <Button Content="Add Radio" Click="OnAddRadioClicked" Padding="10,6" Background="{DynamicResource AppButtonNormalBrush}" Foreground="{DynamicResource AppButtonForegroundBrush}" />
                            <Button Content="Remove" Click="OnRemoveRadioClicked" Padding="10,6" Background="{DynamicResource AppButtonDangerBrush}" Foreground="{DynamicResource AppButtonForegroundBrush}" />
                            <Button Content="Edit" Click="OnEditSelectedRadioClicked" Padding="10,6" Background="{DynamicResource AppButtonNormalBrush}" Foreground="{DynamicResource AppButtonForegroundBrush}" />
                        </StackPanel>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Active Radios" VerticalAlignment="Top" />
                        <ListBox Grid.Row="1" Grid.Column="1"
                                 Name="ActiveRadiosListBox"
                                 ItemsSource="{Binding AvailableRigRadioOptions}"
                                 SelectionMode="Multiple,Toggle"
                                 SelectionChanged="OnActiveRigRadiosSelectionChanged"
                                 Height="110"
                                 BorderBrush="{DynamicResource AppBorderBrush}"
                                 Background="{DynamicResource AppPanelBackgroundBrush}"
                                 Foreground="{DynamicResource AppForegroundBrush}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <CheckBox IsChecked="{Binding IsActive}" IsHitTestVisible="False" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Display}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
                        <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource AppMutedForegroundBrush}" Text="Use Edit to configure the radio identifier (used as tag/name), args, host/port, serial port, rig list, and model search." />
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ── Footer ───────────────────────────────────────────── -->
        <StackPanel Grid.Row="2" Spacing="6" Margin="0,8,0,4">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Save" Click="OnSaveClicked" Padding="14,8" Background="{DynamicResource AppButtonNormalBrush}" Foreground="{DynamicResource AppButtonForegroundBrush}" />
                <Button Content="Close" Click="OnCloseClicked" Padding="14,8" Background="{DynamicResource AppButtonCautionBrush}" Foreground="{DynamicResource AppButtonForegroundBrush}" />
            </StackPanel>
            <TextBlock Text="{Binding ConfigFilePath}" FontSize="11" Foreground="{DynamicResource AppMutedForegroundBrush}" />
            <TextBlock Text="{Binding StatusMessage}" FontStyle="Italic" Foreground="{DynamicResource AppAccentBrush}" />
        </StackPanel>
    </Grid>
</Window>
