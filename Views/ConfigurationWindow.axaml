<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HamBusLog.Views.ConfigurationWindow"
        Title="Configuration"
        Width="1020"
        Height="760"
        MinWidth="760"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppForegroundBrush}">
    <Grid RowDefinitions="Auto,*,Auto" Margin="16">

        <!-- ── Active Profile (always visible) ─────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10" Spacing="6" ZIndex="10">
            <TextBlock Text="Configuration" FontSize="22" FontWeight="Bold" />
            <Grid ColumnDefinitions="120,300,Auto" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="Active Profile" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AvailableProfiles}"
                          SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                          Background="{DynamicResource AppPanelBackgroundBrush}"
                          Foreground="{DynamicResource AppForegroundBrush}"
                          MaxDropDownHeight="260"
                          HorizontalAlignment="Stretch">
                    <ComboBox.Styles>
                        <Style Selector="ComboBoxItem">
                            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
                            <Setter Property="Background" Value="{DynamicResource AppPanelBackgroundBrush}" />
                        </Style>
                    </ComboBox.Styles>
                </ComboBox>
                <TextBlock Grid.Column="2"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppMutedForegroundBrush}"
                           Text="{Binding SelectedProfile, StringFormat=Current: {0}}" />
            </Grid>
        </StackPanel>

        <TabControl Grid.Row="1" ZIndex="0">

            <!-- ── Config Tab ───────────────────────────────────── -->
            <TabItem Header="Config">
                <StackPanel Margin="12" Spacing="12">
                    <TextBlock Text="Clone Profile" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock Text="Optionally enter a name below, then click Clone to duplicate the active profile." Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox Text="{Binding NewProfileName}"
                                 Watermark="New name (blank = auto)"
                                 Width="280" />
                        <Button Content="Clone Profile" Click="OnCloneProfileClicked" Padding="12,6" Background="{DynamicResource AppButtonNormalBrush}" Foreground="{DynamicResource AppButtonNormalForegroundBrush}" />
                    </StackPanel>

                    <Separator Margin="0,6,0,0" />

                    <TextBlock Text="ADIF Import Directory" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock Text="Used as the default starting folder when selecting ADIF files to import." Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox Text="{Binding AdifDirectory}"
                                 Watermark="/home/you/logs/adif"
                                 Width="420" />
                        <Button Content="Browse..." Click="OnBrowseAdifDirectoryClicked" Padding="10,6" Background="{DynamicResource AppButtonCautionBrush}" Foreground="{DynamicResource AppButtonCautionForegroundBrush}" />
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- ── Colors Tab ────────────────────────────────────── -->
            <TabItem Header="Colors">
                <ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="18">
                            <StackPanel Grid.Column="0" Spacing="16">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Background Color" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                            <ColorPicker Name="BgColorPicker" />
                                        </Border>
                                        <TextBlock Name="BgColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="Foreground Color" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                            <ColorPicker Name="FgColorPicker" />
                                        </Border>
                                        <TextBlock Name="FgColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="Menu Background" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                            <ColorPicker Name="MenuBgColorPicker" />
                                        </Border>
                                        <TextBlock Name="MenuBgColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="Menu Foreground" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                            <ColorPicker Name="MenuFgColorPicker" />
                                        </Border>
                                        <TextBlock Name="MenuFgColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="Button: Normal" FontWeight="SemiBold" />
                                    <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowDefinitions="Auto,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Background" VerticalAlignment="Center" />
                                        <Border Grid.Row="0" Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                            <ColorPicker Name="BtnNormalColorPicker" />
                                        </Border>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Name="BtnNormalColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Foreground" VerticalAlignment="Center" />
                                        <Border Grid.Row="1" Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                            <ColorPicker Name="BtnNormalFgColorPicker" />
                                        </Border>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Name="BtnNormalFgColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                                    </Grid>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="16">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Button: Caution" FontWeight="SemiBold" />
                                    <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowDefinitions="Auto,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Background" VerticalAlignment="Center" />
                                        <Border Grid.Row="0" Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                            <ColorPicker Name="BtnCautionColorPicker" />
                                        </Border>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Name="BtnCautionColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Foreground" VerticalAlignment="Center" />
                                        <Border Grid.Row="1" Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                            <ColorPicker Name="BtnCautionFgColorPicker" />
                                        </Border>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Name="BtnCautionFgColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                                    </Grid>
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="Button: Danger" FontWeight="SemiBold" />
                                    <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowDefinitions="Auto,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Background" VerticalAlignment="Center" />
                                        <Border Grid.Row="0" Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                            <ColorPicker Name="BtnDangerColorPicker" />
                                        </Border>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Name="BtnDangerColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Foreground" VerticalAlignment="Center" />
                                        <Border Grid.Row="1" Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                            <ColorPicker Name="BtnDangerFgColorPicker" />
                                        </Border>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Name="BtnDangerFgColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                                    </Grid>
                                </StackPanel>

                                <TextBlock Text="Input Controls" FontWeight="SemiBold" FontSize="14" />

                                <StackPanel Spacing="6">
                                    <TextBlock Text="Input Background" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                            <ColorPicker Name="InputBgColorPicker" />
                                        </Border>
                                        <TextBlock Name="InputBgColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="Input Foreground" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                            <ColorPicker Name="InputFgColorPicker" />
                                        </Border>
                                        <TextBlock Name="InputFgColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="Input Border" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                            <ColorPicker Name="InputBorderColorPicker" />
                                        </Border>
                                        <TextBlock Name="InputBorderColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="16">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Input Selection Background" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                            <ColorPicker Name="InputSelectionBgColorPicker" />
                                        </Border>
                                        <TextBlock Name="InputSelectionBgColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="Input Selection Foreground" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource AppPanelBackgroundBrush}">
                                            <ColorPicker Name="InputSelectionFgColorPicker" />
                                        </Border>
                                        <TextBlock Name="InputSelectionFgColorHex" VerticalAlignment="Center" FontFamily="Monospace" FontSize="13" />
                                    </StackPanel>
                                </StackPanel>

                                <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="10" Background="{DynamicResource AppPanelBackgroundBrush}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Tips" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource AppForegroundBrush}" />
                                        <TextBlock Text="The preview below shows how these colors will look in the app." TextWrapping="Wrap" Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                                        <TextBlock Text="Normal is used for primary actions and selected tabs." TextWrapping="Wrap" Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                                        <TextBlock Text="Caution is used for browse/cancel style actions." TextWrapping="Wrap" Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                                        <TextBlock Text="Danger is used for destructive actions like remove/delete." TextWrapping="Wrap" Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="10" Background="{DynamicResource AppPanelBackgroundBrush}" Margin="0,8,0,0">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Live Preview" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource AppForegroundBrush}" />

                            <Border Background="{DynamicResource AppMenuBackgroundBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="8">
                                <TextBlock Text="Menu Preview" Foreground="{DynamicResource AppMenuForegroundBrush}" FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Name="MenuContrastLabel" Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Border Background="{DynamicResource AppButtonNormalBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10,5">
                                    <TextBlock Text="Selected Tab" Foreground="{DynamicResource AppButtonNormalForegroundBrush}" />
                                </Border>
                                <Border Background="{DynamicResource AppHeaderBackgroundBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10,5">
                                    <TextBlock Text="Tab" Foreground="{DynamicResource AppForegroundBrush}" />
                                </Border>
                                <Border Background="{DynamicResource AppPanelBackgroundBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10,5">
                                    <TextBlock Text="Hover Tab" Foreground="{DynamicResource AppForegroundBrush}" />
                                </Border>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Normal" Background="{DynamicResource AppButtonNormalBrush}" Foreground="{DynamicResource AppButtonNormalForegroundBrush}" Padding="12,6" />
                                <Button Content="Caution" Background="{DynamicResource AppButtonCautionBrush}" Foreground="{DynamicResource AppButtonCautionForegroundBrush}" Padding="12,6" />
                                <Button Content="Danger" Background="{DynamicResource AppButtonDangerBrush}" Foreground="{DynamicResource AppButtonDangerForegroundBrush}" Padding="12,6" />
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock Name="ButtonNormalContrastLabel" Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                                <TextBlock Name="ButtonCautionContrastLabel" Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                                <TextBlock Name="ButtonDangerContrastLabel" Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Database Tab ──────────────────────────────────── -->
            <TabItem Header="Database">
                <StackPanel Margin="12" Spacing="12">
                    <TextBlock Text="Database Location (SQLite)" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock Text="Choose a folder and filename. These values are stored in config and used to build the SQLite connection string." Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox Text="{Binding DatabaseFolderPath}"
                                 Watermark="/home/you/.local/share/hambuslog"
                                 Width="520" />
                        <Button Content="Browse Folder..." Click="OnBrowseDatabaseDirectoryClicked" Padding="10,6" Background="{DynamicResource AppButtonCautionBrush}" Foreground="{DynamicResource AppButtonCautionForegroundBrush}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox Text="{Binding DatabaseFileName}"
                                 Watermark="hambuslog.db"
                                 Width="240" />
                        <TextBlock Text="Combined path:" VerticalAlignment="Center" Foreground="{DynamicResource AppMutedForegroundBrush}" />
                        <TextBlock Text="{Binding DatabaseFilePath}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Width="420" />
                    </StackPanel>

                    <Separator Margin="0,2,0,2" />

                    <TextBlock Text="Connection String" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock Text="SQLite example: Data Source=hambuslog.db" Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                    <TextBlock Text="PostgreSQL example: Host=localhost;Database=hamlog;Username=ham;Password=..." Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                    <TextBox Text="{Binding ConnectionString}"
                             Watermark="Data Source=hambuslog.db"
                             AcceptsReturn="False" />
                </StackPanel>
            </TabItem>

            <!-- ── Rig Control Tab ──────────────────────────────────── -->
            <TabItem Header="Rig Control">
                <ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                        <Border Padding="14"
                                CornerRadius="8"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <StackPanel Spacing="4">
                                <TextBlock Text="rigctld Configuration" FontWeight="SemiBold" FontSize="15" />
                                <TextBlock Text="Manage radios here, then open the editor dialog for detailed rigctld fields."
                                           Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                            </StackPanel>
                        </Border>

                        <Border Padding="14"
                                CornerRadius="8"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="12">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Radio" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <ComboBox ItemsSource="{Binding AvailableRigRadioOptions}"
                                              SelectedItem="{Binding SelectedRigRadio, Mode=TwoWay}"
                                              DisplayMemberBinding="{Binding Display}"
                                              Width="240"
                                              IsEditable="False"
                                              HorizontalAlignment="Left" />
                                    <Button Content="Add Radio" Click="OnAddRadioClicked" Padding="12,7" Background="{DynamicResource AppButtonNormalBrush}" Foreground="{DynamicResource AppButtonNormalForegroundBrush}" />
                                    <Button Content="Edit" Click="OnEditSelectedRadioClicked" Padding="12,7" Background="{DynamicResource AppButtonNormalBrush}" Foreground="{DynamicResource AppButtonNormalForegroundBrush}" />
                                    <Button Content="Remove" Click="OnRemoveRadioClicked" Padding="12,7" Background="{DynamicResource AppButtonDangerBrush}" Foreground="{DynamicResource AppButtonDangerForegroundBrush}" />
                                </StackPanel>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Active Radios" VerticalAlignment="Top" FontWeight="SemiBold" />
                                <Border Grid.Row="1" Grid.Column="1"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="0"
                                        Background="{DynamicResource AppWindowBackgroundBrush}">
                                    <ListBox Name="ActiveRadiosListBox"
                                             ItemsSource="{Binding AvailableRigRadioOptions}"
                                             SelectionMode="Multiple,Toggle"
                                             SelectionChanged="OnActiveRigRadiosSelectionChanged"
                                             Height="126"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="{DynamicResource AppForegroundBrush}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="8,6">
                                                    <CheckBox IsChecked="{Binding IsActive}" IsHitTestVisible="False" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Display}" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Padding="14"
                                CornerRadius="8"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="12">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Rig List" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <TextBox Text="{Binding RiglistFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="460" />
                                    <Button Content="Browse..." Click="OnBrowseRiglistClicked" Padding="10,7" Background="{DynamicResource AppButtonCautionBrush}" Foreground="{DynamicResource AppButtonCautionForegroundBrush}" />
                                    <Button Content="Load" Click="OnLoadRiglistClicked" Padding="10,7" Background="{DynamicResource AppButtonCautionBrush}" Foreground="{DynamicResource AppButtonCautionForegroundBrush}" />
                                    <Button Content="Reload" Click="OnCatalogReloadClicked" Padding="10,7" Background="{DynamicResource AppButtonCautionBrush}" Foreground="{DynamicResource AppButtonCautionForegroundBrush}" />
                                </StackPanel>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Reconnect (sec)" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="10">
                                    <TextBox Width="120"
                                             Text="{Binding RigctldReconnectIntervalSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="{DynamicResource AppMutedForegroundBrush}"
                                               Text="Use Edit to configure radio fields (name, args, host/port, resource path, and model search)." />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- ── Footer ───────────────────────────────────────────── -->
        <StackPanel Grid.Row="2" Spacing="6" Margin="0,8,0,4">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Save" Click="OnSaveClicked" Padding="14,8" Background="{DynamicResource AppButtonNormalBrush}" Foreground="{DynamicResource AppButtonNormalForegroundBrush}" />
                <Button Content="Close" Click="OnCloseClicked" Padding="14,8" Background="{DynamicResource AppButtonCautionBrush}" Foreground="{DynamicResource AppButtonCautionForegroundBrush}" />
            </StackPanel>
            <TextBlock Text="{Binding ConfigFilePath}" FontSize="11" Foreground="{DynamicResource AppMutedForegroundBrush}" />
            <TextBlock Text="{Binding StatusMessage}" FontStyle="Italic" Foreground="{DynamicResource AppAccentBrush}" />
        </StackPanel>
    </Grid>
</Window>
