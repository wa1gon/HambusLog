<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HamBusLog.Views.ConfigurationWindow"
        Title="Configuration"
        Width="1020"
        Height="760"
        MinWidth="760"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppForegroundBrush}">

    <Window.Styles>
        <Style Selector="TextBlock.FieldLabel">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppMutedForegroundBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style Selector="#ColorsTabContent TextBlock.FieldLabel">
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        </Style>
        <Style Selector="#ColorsTabContent TextBlock.HexValue">
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.CardHeading">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Margin="16,14,16,10">

        <!-- ── Active Profile bar ──────────────────────────────── -->
        <Border Grid.Row="0" Margin="0,0,0,10" Padding="14,10"
                CornerRadius="8"
                Background="{DynamicResource AppPanelBackgroundBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1">
            <Grid ColumnDefinitions="Auto,Auto,300,*" ColumnSpacing="12">
                <TextBlock Grid.Column="0" Text="Configuration"
                           FontSize="20" FontWeight="Bold"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="Active Profile"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppMutedForegroundBrush}"
                           FontSize="12" Margin="12,0,0,0" />
                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding AvailableProfiles}"
                          SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                          MaxDropDownHeight="260"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center">
                    <ComboBox.Styles>
                        <Style Selector="ComboBoxItem">
                            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
                            <Setter Property="Background" Value="{DynamicResource AppPanelBackgroundBrush}" />
                        </Style>
                    </ComboBox.Styles>
                </ComboBox>
                <TextBlock Grid.Column="3"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppMutedForegroundBrush}"
                           FontSize="12"
                           Text="{Binding SelectedProfile, StringFormat=Current: {0}}" />
            </Grid>
        </Border>

        <TabControl Grid.Row="1">

            <!-- ── Config Tab ────────────────────────────────────── -->
            <TabItem Header="Config">
                <ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="10">

                        <Border Padding="14" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="CardHeading" Text="Contest Licensing" />
                                <TextBlock Text="Licenses are configured per contest in the Contests tab using each definition's LicenseKey field."
                                           Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                                <TextBlock Text="Example JSON field: LicenseKey = your-key"
                                           Foreground="{DynamicResource AppMutedForegroundBrush}"
                                           FontFamily="Monospace"
                                           FontSize="11" />
                                <Grid ColumnDefinitions="160,220,220,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="6">
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Application font size"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold" />
                                    <Slider Grid.Row="0" Grid.Column="1"
                                            Minimum="10"
                                            Maximum="24"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding AppFontSize, Mode=TwoWay}" />
                                    <TextBlock Grid.Row="0" Grid.Column="2"
                                               Text="{Binding AppFontSize, StringFormat={}{0:0.#} pt}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource AppMutedForegroundBrush}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="Preset"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold" />
                                    <ComboBox Grid.Row="1" Grid.Column="1"
                                              Width="200"
                                              ItemsSource="{Binding FontSizePresets}"
                                              SelectedItem="{Binding SelectedFontSizePreset, Mode=TwoWay}" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                                               Text="Location: Configuration window -> Config tab -> License card. Applies when you save this profile."
                                               FontSize="11"
                                               Foreground="{DynamicResource AppMutedForegroundBrush}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Padding="14" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="CardHeading" Text="Clone Profile" />
                                <TextBlock Text="Optionally enter a name below, then click Clone to duplicate the active profile."
                                           Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBox Text="{Binding NewProfileName}"
                                             Watermark="New name (blank = auto)"
                                             Width="280" Padding="8,7" />
                                    <Button Content="Clone Profile" Click="OnCloneProfileClicked"
                                            Padding="14,7"
                                            Background="{DynamicResource AppButtonNormalBrush}"
                                            Foreground="{DynamicResource AppButtonNormalForegroundBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Padding="14" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="CardHeading" Text="ADIF Import Directory" />
                                <TextBlock Text="Used as the default starting folder when selecting ADIF files to import."
                                           Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBox Text="{Binding AdifDirectory}"
                                             Watermark="/home/you/logs/adif"
                                             Width="460" Padding="8,7" />
                                    <Button Content="Browse..." Click="OnBrowseAdifDirectoryClicked"
                                            Padding="12,7"
                                            Background="{DynamicResource AppButtonCautionBrush}"
                                            Foreground="{DynamicResource AppButtonCautionForegroundBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Station Tab ───────────────────────────────────── -->
            <TabItem Header="Station">
                <ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="10">

                        <Border Padding="14" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="CardHeading" Text="Station Identity" />
                                <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Callsign" VerticalAlignment="Center" FontWeight="SemiBold" />
                                    <TextBox Grid.Row="0" Grid.Column="1"
                                             Text="{Binding MyCall, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Watermark="N0CALL"
                                             Width="220"
                                             HorizontalAlignment="Left"
                                             Padding="8,7"
                                             FontWeight="SemiBold" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Location" VerticalAlignment="Center" FontWeight="SemiBold" />
                                    <TextBox Grid.Row="1" Grid.Column="1"
                                             Text="{Binding MyLocation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Watermark="Home, portable site, club station..."
                                             Width="420"
                                             HorizontalAlignment="Left"
                                             Padding="8,7" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Padding="14" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="CardHeading" Text="Station Location" />
                                <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Latitude / Longitude" VerticalAlignment="Center" FontWeight="SemiBold" />
                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="10">
                                        <TextBox Text="{Binding MyLatitude, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Watermark="42.3601" Width="150" Padding="8,7" />
                                        <TextBox Text="{Binding MyLongitude, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Watermark="-71.0589" Width="150" Padding="8,7" />
                                    </StackPanel>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Grid Square" VerticalAlignment="Center" FontWeight="SemiBold" />
                                    <TextBox Grid.Row="1" Grid.Column="1"
                                             Text="{Binding MyGridSquare, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Watermark="FN42"
                                             Width="150"
                                             HorizontalAlignment="Left"
                                             Padding="8,7" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="ITU / CQ Zone" VerticalAlignment="Center" FontWeight="SemiBold" />
                                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="10">
                                        <TextBox Text="{Binding MyItuZone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Watermark="8" Width="90" Padding="8,7" />
                                        <TextBox Text="{Binding MyCqZone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Watermark="5" Width="90" Padding="8,7" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Padding="14" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="CardHeading" Text="Field Day Station" />
                                <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Section" VerticalAlignment="Center" FontWeight="SemiBold" />
                                    <TextBox Grid.Row="0" Grid.Column="1"
                                             Text="{Binding MyFieldDaySection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Watermark="EMA"
                                             Width="150"
                                             HorizontalAlignment="Left"
                                             Padding="8,7" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Class" VerticalAlignment="Center" FontWeight="SemiBold" />
                                    <TextBox Grid.Row="1" Grid.Column="1"
                                             Text="{Binding MyFieldDayClass, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Watermark="1D"
                                             Width="150"
                                             HorizontalAlignment="Left"
                                             Padding="8,7" />
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Colors Tab ────────────────────────────────────── -->
            <TabItem Header="Colors">
                <ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto">
                    <StackPanel Name="ColorsTabContent" Spacing="10">

                        <Border Padding="10" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Content="Reset to Default Colors"
                                        Click="OnResetColorsClicked"
                                        Padding="14,7"
                                        Background="{DynamicResource AppButtonCautionBrush}"
                                        Foreground="{DynamicResource AppButtonCautionForegroundBrush}" />
                                <TextBlock Text="Restores a readable default palette. Save to apply across the app."
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppMutedForegroundBrush}" />
                            </StackPanel>
                        </Border>

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                        <Border Name="ThemeColorCardBorder" Grid.Row="0" Grid.Column="0" Padding="14" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" Classes="CardHeading" Text="Theme Colors" />
                                    <TextBlock Grid.Column="1" Name="ThemeAaFlagLabel" FontSize="12" VerticalAlignment="Center" />
                                </Grid>
                                <TextBlock Name="ThemeAaFailuresLabel" FontSize="12" Foreground="{DynamicResource AppMutedForegroundBrush}" />
                                <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="FieldLabel" Text="BACKGROUND" VerticalAlignment="Center" />
                                    <Border Grid.Row="0" Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="5" CornerRadius="4" Background="{DynamicResource AppWindowBackgroundBrush}">
                                        <ColorPicker Name="BgColorPicker" />
                                    </Border>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Name="BgColorHex" Classes="HexValue" VerticalAlignment="Center" FontFamily="Monospace" FontSize="12" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="FieldLabel" Text="FOREGROUND" VerticalAlignment="Center" />
                                    <Border Grid.Row="1" Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="5" CornerRadius="4" Background="{DynamicResource AppWindowBackgroundBrush}">
                                        <ColorPicker Name="FgColorPicker" />
                                    </Border>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Name="FgColorHex" Classes="HexValue" VerticalAlignment="Center" FontFamily="Monospace" FontSize="12" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="FieldLabel" Text="MUTED / LABEL COLOR" VerticalAlignment="Center" />
                                    <Border Grid.Row="2" Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="5" CornerRadius="4" Background="{DynamicResource AppWindowBackgroundBrush}">
                                        <ColorPicker Name="MutedFgColorPicker" />
                                    </Border>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Name="MutedFgColorHex" Classes="HexValue" VerticalAlignment="Center" FontFamily="Monospace" FontSize="12" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Name="MenuColorCardBorder" Grid.Row="0" Grid.Column="1" Padding="14" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" Classes="CardHeading" Text="Menu Colors" />
                                    <TextBlock Grid.Column="1" Name="MenuAaFlagLabel" FontSize="12" VerticalAlignment="Center" />
                                </Grid>
                                <TextBlock Name="MenuAaFailuresLabel" FontSize="12" Foreground="{DynamicResource AppMutedForegroundBrush}" />
                                <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10" RowDefinitions="Auto,Auto" RowSpacing="8">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="FieldLabel" Text="MENU BACKGROUND" VerticalAlignment="Center" />
                                    <Border Grid.Row="0" Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="5" CornerRadius="4" Background="{DynamicResource AppWindowBackgroundBrush}">
                                        <ColorPicker Name="MenuBgColorPicker" />
                                    </Border>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Name="MenuBgColorHex" Classes="HexValue" VerticalAlignment="Center" FontFamily="Monospace" FontSize="12" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="FieldLabel" Text="MENU FOREGROUND" VerticalAlignment="Center" />
                                    <Border Grid.Row="1" Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="5" CornerRadius="4" Background="{DynamicResource AppWindowBackgroundBrush}">
                                        <ColorPicker Name="MenuFgColorPicker" />
                                    </Border>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Name="MenuFgColorHex" Classes="HexValue" VerticalAlignment="Center" FontFamily="Monospace" FontSize="12" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Name="ButtonColorCardBorder" Grid.Row="1" Grid.Column="0" Padding="14" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" Classes="CardHeading" Text="Button Colors" />
                                    <TextBlock Grid.Column="1" Name="ButtonAaFlagLabel" FontSize="12" VerticalAlignment="Center" />
                                </Grid>
                                <TextBlock Name="ButtonAaFailuresLabel" FontSize="12" Foreground="{DynamicResource AppMutedForegroundBrush}" />
                                <Grid ColumnDefinitions="70,Auto,Auto" ColumnSpacing="8" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="6">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Normal Bg" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource AppMutedForegroundBrush}" />
                                    <Border Grid.Row="0" Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="5" CornerRadius="4" Background="{DynamicResource AppWindowBackgroundBrush}">
                                        <ColorPicker Name="BtnNormalColorPicker" />
                                    </Border>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Name="BtnNormalColorHex" Classes="HexValue" VerticalAlignment="Center" FontFamily="Monospace" FontSize="12" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Normal Fg" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource AppMutedForegroundBrush}" />
                                    <Border Grid.Row="1" Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="5" CornerRadius="4" Background="{DynamicResource AppWindowBackgroundBrush}">
                                        <ColorPicker Name="BtnNormalFgColorPicker" />
                                    </Border>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Name="BtnNormalFgColorHex" Classes="HexValue" VerticalAlignment="Center" FontFamily="Monospace" FontSize="12" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Caution Bg" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource AppMutedForegroundBrush}" />
                                    <Border Grid.Row="2" Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="5" CornerRadius="4" Background="{DynamicResource AppWindowBackgroundBrush}">
                                        <ColorPicker Name="BtnCautionColorPicker" />
                                    </Border>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Name="BtnCautionColorHex" Classes="HexValue" VerticalAlignment="Center" FontFamily="Monospace" FontSize="12" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Caution Fg" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource AppMutedForegroundBrush}" />
                                    <Border Grid.Row="3" Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="5" CornerRadius="4" Background="{DynamicResource AppWindowBackgroundBrush}">
                                        <ColorPicker Name="BtnCautionFgColorPicker" />
                                    </Border>
                                    <TextBlock Grid.Row="3" Grid.Column="2" Name="BtnCautionFgColorHex" Classes="HexValue" VerticalAlignment="Center" FontFamily="Monospace" FontSize="12" />

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Danger Bg" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource AppMutedForegroundBrush}" />
                                    <Border Grid.Row="4" Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="5" CornerRadius="4" Background="{DynamicResource AppWindowBackgroundBrush}">
                                        <ColorPicker Name="BtnDangerColorPicker" />
                                    </Border>
                                    <TextBlock Grid.Row="4" Grid.Column="2" Name="BtnDangerColorHex" Classes="HexValue" VerticalAlignment="Center" FontFamily="Monospace" FontSize="12" />

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Danger Fg" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource AppMutedForegroundBrush}" />
                                    <Border Grid.Row="5" Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="5" CornerRadius="4" Background="{DynamicResource AppWindowBackgroundBrush}">
                                        <ColorPicker Name="BtnDangerFgColorPicker" />
                                    </Border>
                                    <TextBlock Grid.Row="5" Grid.Column="2" Name="BtnDangerFgColorHex" Classes="HexValue" VerticalAlignment="Center" FontFamily="Monospace" FontSize="12" />
                                </Grid>

                                <Border CornerRadius="6" BorderThickness="1"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        Background="{DynamicResource AppWindowBackgroundBrush}"
                                        Padding="10">
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="FieldLabel" Text="TIPS" />
                                        <TextBlock Text="Normal → primary actions and selected tabs." TextWrapping="Wrap" Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                                        <TextBlock Text="Caution → browse / cancel style actions." TextWrapping="Wrap" Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                                        <TextBlock Text="Danger → destructive actions like remove / delete." TextWrapping="Wrap" Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Name="InputColorCardBorder" Grid.Row="1" Grid.Column="1" Padding="14" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" Classes="CardHeading" Text="Input Colors" />
                                    <TextBlock Grid.Column="1" Name="InputAaFlagLabel" FontSize="12" VerticalAlignment="Center" />
                                </Grid>
                                <TextBlock Name="InputAaFailuresLabel" FontSize="12" Foreground="{DynamicResource AppMutedForegroundBrush}" />
                                <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="FieldLabel" Text="INPUT BACKGROUND" VerticalAlignment="Center" />
                                    <Border Grid.Row="0" Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="5" CornerRadius="4" Background="{DynamicResource AppWindowBackgroundBrush}">
                                        <ColorPicker Name="InputBgColorPicker" />
                                    </Border>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Name="InputBgColorHex" Classes="HexValue" VerticalAlignment="Center" FontFamily="Monospace" FontSize="12" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="FieldLabel" Text="INPUT FOREGROUND" VerticalAlignment="Center" />
                                    <Border Grid.Row="1" Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="5" CornerRadius="4" Background="{DynamicResource AppWindowBackgroundBrush}">
                                        <ColorPicker Name="InputFgColorPicker" />
                                    </Border>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Name="InputFgColorHex" Classes="HexValue" VerticalAlignment="Center" FontFamily="Monospace" FontSize="12" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="FieldLabel" Text="INPUT BORDER" VerticalAlignment="Center" />
                                    <Border Grid.Row="2" Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="5" CornerRadius="4" Background="{DynamicResource AppWindowBackgroundBrush}">
                                        <ColorPicker Name="InputBorderColorPicker" />
                                    </Border>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Name="InputBorderColorHex" Classes="HexValue" VerticalAlignment="Center" FontFamily="Monospace" FontSize="12" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Classes="FieldLabel" Text="INPUT SELECTION BACKGROUND" VerticalAlignment="Center" />
                                    <Border Grid.Row="3" Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="5" CornerRadius="4" Background="{DynamicResource AppWindowBackgroundBrush}">
                                        <ColorPicker Name="InputSelectionBgColorPicker" />
                                    </Border>
                                    <TextBlock Grid.Row="3" Grid.Column="2" Name="InputSelectionBgColorHex" Classes="HexValue" VerticalAlignment="Center" FontFamily="Monospace" FontSize="12" />

                                    <TextBlock Grid.Row="4" Grid.Column="0" Classes="FieldLabel" Text="INPUT SELECTION FOREGROUND" VerticalAlignment="Center" />
                                    <Border Grid.Row="4" Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="5" CornerRadius="4" Background="{DynamicResource AppWindowBackgroundBrush}">
                                        <ColorPicker Name="InputSelectionFgColorPicker" />
                                    </Border>
                                    <TextBlock Grid.Row="4" Grid.Column="2" Name="InputSelectionFgColorHex" Classes="HexValue" VerticalAlignment="Center" FontFamily="Monospace" FontSize="12" />
                                </Grid>
                            </StackPanel>
                        </Border>
                        </Grid>

                        <!-- Live Preview -->
                        <Border Padding="14" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="CardHeading" Text="Live Preview" />
                                <Border Background="{DynamicResource AppMenuBackgroundBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1" CornerRadius="5" Padding="10,7">
                                    <TextBlock Text="Menu Preview" Foreground="{DynamicResource AppMenuForegroundBrush}" FontWeight="SemiBold" />
                                </Border>
                                <TextBlock Name="MenuContrastLabel" Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                                <Border Background="{DynamicResource AppPanelBackgroundBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1" CornerRadius="5" Padding="10,8">
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="Primary text sample" Foreground="{DynamicResource AppForegroundBrush}" />
                                        <TextBlock Text="Muted label / helper text sample" Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Name="MutedContrastLabel" Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Background="{DynamicResource AppButtonNormalBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="5" Padding="12,6">
                                        <TextBlock Text="Selected Tab" Foreground="{DynamicResource AppButtonNormalForegroundBrush}" />
                                    </Border>
                                    <Border Background="{DynamicResource AppHeaderBackgroundBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="5" Padding="12,6">
                                        <TextBlock Text="Tab" Foreground="{DynamicResource AppForegroundBrush}" />
                                    </Border>
                                    <Border Background="{DynamicResource AppPanelBackgroundBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="5" Padding="12,6">
                                        <TextBlock Text="Hover Tab" Foreground="{DynamicResource AppForegroundBrush}" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Normal"  Background="{DynamicResource AppButtonNormalBrush}"  Foreground="{DynamicResource AppButtonNormalForegroundBrush}"  Padding="14,7" />
                                    <Button Content="Caution" Background="{DynamicResource AppButtonCautionBrush}" Foreground="{DynamicResource AppButtonCautionForegroundBrush}" Padding="14,7" />
                                    <Button Content="Danger"  Background="{DynamicResource AppButtonDangerBrush}"  Foreground="{DynamicResource AppButtonDangerForegroundBrush}"  Padding="14,7" />
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Name="ButtonNormalContrastLabel"  Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                                    <TextBlock Name="ButtonCautionContrastLabel" Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                                    <TextBlock Name="ButtonDangerContrastLabel"  Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Database Tab ──────────────────────────────────── -->
            <TabItem Header="Database">
                <ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="10">

                        <Border Padding="14" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="CardHeading" Text="Database Location (SQLite)" />
                                <TextBlock Text="Choose a folder and filename. These values are stored in config and used to build the SQLite connection string."
                                           Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                                <Grid ColumnDefinitions="80,*" ColumnSpacing="10" RowDefinitions="Auto,Auto" RowSpacing="8">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Folder" VerticalAlignment="Center"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="{DynamicResource AppMutedForegroundBrush}" />
                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <TextBox Text="{Binding DatabaseFolderPath}"
                                                 Watermark="/home/you/.local/share/hambuslog"
                                                 Width="500" Padding="8,7" />
                                        <Button Content="Browse..." Click="OnBrowseDatabaseDirectoryClicked"
                                                Padding="12,7"
                                                Background="{DynamicResource AppButtonCautionBrush}"
                                                Foreground="{DynamicResource AppButtonCautionForegroundBrush}" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="File" VerticalAlignment="Center"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="{DynamicResource AppMutedForegroundBrush}" />
                                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="10">
                                        <TextBox Text="{Binding DatabaseFileName}"
                                                 Watermark="hambuslog.db"
                                                 Width="200" Padding="8,7" />
                                        <TextBlock Text="{Binding DatabaseFilePath}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource AppMutedForegroundBrush}"
                                                   FontSize="12" MaxWidth="360" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Padding="14" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="CardHeading" Text="Connection String" />
                                <StackPanel Spacing="2">
                                    <TextBlock Text="SQLite example: Data Source=hambuslog.db"
                                               Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" FontFamily="Monospace" />
                                    <TextBlock Text="PostgreSQL example: Host=localhost;Database=hamlog;Username=ham;Password=..."
                                               Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" FontFamily="Monospace" />
                                </StackPanel>
                                <TextBox Text="{Binding ConnectionString}"
                                         Watermark="Data Source=hambuslog.db"
                                         Padding="8,7"
                                         AcceptsReturn="False" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Rig Control Tab ──────────────────────────────────── -->
            <TabItem Header="Rig Control">
                <ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="10">

                        <Border Padding="14" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="CardHeading" Text="rigctld Configuration" />
                                <TextBlock Text="Manage radios here, then open the editor dialog for detailed rigctld fields."
                                           Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                            </StackPanel>
                        </Border>

                        <Border Padding="14" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="12">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Radio" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <ComboBox ItemsSource="{Binding AvailableRigRadioOptions}"
                                              SelectedItem="{Binding SelectedRigRadio, Mode=TwoWay}"
                                              DisplayMemberBinding="{Binding Display}"
                                              Width="240" IsEditable="False"
                                              HorizontalAlignment="Left" />
                                    <Button Content="Add Radio" Click="OnAddRadioClicked" Padding="12,7" Background="{DynamicResource AppButtonNormalBrush}" Foreground="{DynamicResource AppButtonNormalForegroundBrush}" />
                                    <Button Content="Edit" Click="OnEditSelectedRadioClicked" Padding="12,7" Background="{DynamicResource AppButtonNormalBrush}" Foreground="{DynamicResource AppButtonNormalForegroundBrush}" />
                                    <Button Content="Remove" Click="OnRemoveRadioClicked" Padding="12,7" Background="{DynamicResource AppButtonDangerBrush}" Foreground="{DynamicResource AppButtonDangerForegroundBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Active Radios" VerticalAlignment="Top" FontWeight="SemiBold" />
                                <Border Grid.Row="1" Grid.Column="1"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="0"
                                        Background="{DynamicResource AppWindowBackgroundBrush}">
                                    <ListBox Name="ActiveRadiosListBox"
                                             ItemsSource="{Binding AvailableRigRadioOptions}"
                                             SelectionMode="Multiple,Toggle"
                                             SelectionChanged="OnActiveRigRadiosSelectionChanged"
                                             Height="126" BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="{DynamicResource AppForegroundBrush}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="8,6">
                                                    <CheckBox IsChecked="{Binding IsActive}" IsHitTestVisible="False" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Display}" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Padding="14" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="12">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Rig List" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <TextBox Text="{Binding RiglistFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="460" Padding="8,7" />
                                    <Button Content="Browse..." Click="OnBrowseRiglistClicked" Padding="10,7" Background="{DynamicResource AppButtonCautionBrush}" Foreground="{DynamicResource AppButtonCautionForegroundBrush}" />
                                    <Button Content="Load" Click="OnLoadRiglistClicked" Padding="10,7" Background="{DynamicResource AppButtonCautionBrush}" Foreground="{DynamicResource AppButtonCautionForegroundBrush}" />
                                    <Button Content="Reload" Click="OnCatalogReloadClicked" Padding="10,7" Background="{DynamicResource AppButtonCautionBrush}" Foreground="{DynamicResource AppButtonCautionForegroundBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Reconnect (sec)" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="12">
                                    <TextBox Width="120" Padding="8,7"
                                             Text="{Binding RigctldReconnectIntervalSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12"
                                               Text="Use Edit to configure radio fields (name, args, host/port, resource path, and model search)." />
                                </StackPanel>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Contests">
                <ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="10">
                        <Border Padding="14" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="CardHeading" Text="Contest Definitions (JSON)" />
                                <TextBlock Text="Define contest exchanges, ADIF IDs, and per-contest LicenseKey values here."
                                           Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                                <TextBox Text="{Binding ContestDefinitionsJson, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         FontFamily="Monospace"
                                         MinHeight="340"
                                         Padding="8,7" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Cluster Tab ─────────────────────────────────────── -->
            <TabItem Header="Cluster">
                <ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="10">

                        <Border Padding="14" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="CardHeading" Text="DX Cluster Configuration" />
                                <TextBlock Text="Connection and startup command settings for your cluster client."
                                           Foreground="{DynamicResource AppMutedForegroundBrush}" FontSize="12" />
                            </StackPanel>
                        </Border>

                        <Border Padding="14" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Hostname" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ClusterHostname}" Watermark="dxc.example.net" Width="320" Padding="8,7" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="TCP Port" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ClusterTcpPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120" Padding="8,7" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Callsign" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ClusterCallsign}" Watermark="K1ABC" Width="220" Padding="8,7" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Password" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding ClusterPassword}" Width="220" Padding="8,7" />

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Command" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding ClusterCommand}" Watermark="set/filter ..." Width="460" Padding="8,7" />

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Queue Length" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding ClusterQueueLength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120" Padding="8,7" />
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- ── Footer ────────────────────────────────────────────── -->
        <Border Grid.Row="2" Padding="0,10,0,2"
                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <Button Content="Save" Click="OnSaveClicked"
                            Padding="20,9" FontWeight="Bold"
                            Background="{DynamicResource AppButtonNormalBrush}"
                            Foreground="{DynamicResource AppButtonNormalForegroundBrush}" />
                    <Button Content="Close" Click="OnCloseClicked"
                            Padding="16,9"
                            Background="Transparent"
                            Foreground="{DynamicResource AppMutedForegroundBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1" />
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{Binding ConfigFilePath}" FontSize="11" Foreground="{DynamicResource AppMutedForegroundBrush}" />
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" FontStyle="Italic" Foreground="{DynamicResource AppAccentBrush}" />
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
