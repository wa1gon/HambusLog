<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HamBusLog.Views.GridWindow"
        Title="Ham Radio Log Grid"
        Width="900"
        Height="600"
        WindowStartupLocation="CenterScreen">
    <Grid RowDefinitions="Auto,*" ColumnDefinitions="*">
        <!-- Header row -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="8" BorderBrush="#34495E" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="80,150,100,80,80,*">
                <TextBlock Grid.Column="0" Text="Call" Foreground="White" FontWeight="Bold" />
                <TextBlock Grid.Column="1" Text="Date/Time" Foreground="White" FontWeight="Bold" />
                <TextBlock Grid.Column="2" Text="Frequency" Foreground="White" FontWeight="Bold" />
                <TextBlock Grid.Column="3" Text="Mode" Foreground="White" FontWeight="Bold" />
                <TextBlock Grid.Column="4" Text="RST" Foreground="White" FontWeight="Bold" />
                <TextBlock Grid.Column="5" Text="Comments" Foreground="White" FontWeight="Bold" />
            </Grid>
        </Border>

        <!-- Data rows -->
        <ListBox Grid.Row="1" ItemsSource="{Binding LogEntries}" Background="#2C3E50" BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8" BorderBrush="#34495E" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="80,150,100,80,80,*">
                            <TextBlock Grid.Column="0" Text="{Binding Call}" Foreground="White" />
                            <TextBlock Grid.Column="1" Text="{Binding DateTime}" Foreground="White" />
                            <TextBlock Grid.Column="2" Text="{Binding Frequency}" Foreground="White" />
                            <TextBlock Grid.Column="3" Text="{Binding Mode}" Foreground="White" />
                            <TextBlock Grid.Column="4" Text="{Binding RST}" Foreground="White" />
                            <TextBlock Grid.Column="5" Text="{Binding Comments}" Foreground="White" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>



