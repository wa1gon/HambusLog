<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HamBusLog.Views.GridWindow"
        Title="Ham Radio Log Grid"
        RequestedThemeVariant="Dark"
        Width="1200"
        Height="800"
        WindowStartupLocation="CenterScreen">
    <Grid RowDefinitions="*,Auto" ColumnDefinitions="*">
        <!-- Grid data -->
        <Grid Grid.Row="0" RowDefinitions="Auto,*" ColumnDefinitions="*" Background="#2C3E50">
            <Border Grid.Row="0" Background="#1F2937" Padding="6" BorderBrush="#34495E" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="120,220,140,120,100" ColumnSpacing="8">
                    <Button Grid.Column="0" Content="Call" Tag="Call" Click="OnSortHeaderClick" Background="#1F2937" Foreground="White" BorderBrush="#34495E" />
                    <Button Grid.Column="1" Content="Date/Time" Tag="QsoDate" Click="OnSortHeaderClick" Background="#1F2937" Foreground="White" BorderBrush="#34495E" />
                    <Button Grid.Column="2" Content="Frequency" Tag="Freq" Click="OnSortHeaderClick" Background="#1F2937" Foreground="White" BorderBrush="#34495E" Margin="0,0,4,0" />
                    <Button Grid.Column="3" Content="Mode" Tag="Mode" Click="OnSortHeaderClick" Background="#1F2937" Foreground="White" BorderBrush="#34495E" Margin="4,0,0,0" />
                    <Button Grid.Column="4" Content="RST" Tag="RstRcvd" Click="OnSortHeaderClick" Background="#1F2937" Foreground="White" BorderBrush="#34495E" />
                </Grid>
            </Border>

            <ListBox Grid.Row="1" ItemsSource="{Binding LogEntries}" Background="#2C3E50" BorderThickness="0" Foreground="White">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8" BorderBrush="#34495E" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="120,220,140,120,100" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Text="{Binding Call}" Foreground="White" />
                                <TextBlock Grid.Column="1" Text="{Binding QsoDate, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Foreground="White" />
                                <TextBlock Grid.Column="2" Text="{Binding Freq, StringFormat={}{0:F3}}" Foreground="White" TextAlignment="Right" HorizontalAlignment="Stretch" Margin="0,0,4,0" />
                                <TextBlock Grid.Column="3" Text="{Binding Mode}" Foreground="White" Margin="4,0,0,0" />
                                <TextBlock Grid.Column="4" Text="{Binding RstRcvd}" Foreground="White" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Input panel -->
        <Border Grid.Row="1" Background="#1F2937" Padding="12" BorderBrush="#34495E" BorderThickness="0,1,0,0">
            <ScrollViewer>
                <StackPanel Spacing="8">
                    <TextBlock Text="New Log Entry" FontSize="14" FontWeight="Bold" Foreground="White" />
                    
                    <Grid ColumnDefinitions="1*,1*,1*,1*,1*,1*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                        <!-- Row 1 -->
                        <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4">
                            <TextBlock Text="Call" Foreground="White" FontSize="12" />
                            <TextBox Text="{Binding InputCall}" Background="#2C3E50" Foreground="White" Padding="6" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="0" Spacing="4">
                            <TextBlock Text="Date" Foreground="White" FontSize="12" />
                            <TextBox Text="{Binding InputDate}" Background="#2C3E50" Foreground="White" Padding="6" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Grid.Row="0" Spacing="4">
                            <TextBlock Text="Band" Foreground="White" FontSize="12" />
                            <TextBox Text="{Binding InputBand}" Background="#2C3E50" Foreground="White" Padding="6" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Grid.Row="0" Spacing="4">
                            <TextBlock Text="Mode" Foreground="White" FontSize="12" />
                            <TextBox Text="{Binding InputMode}" Background="#2C3E50" Foreground="White" Padding="6" />
                        </StackPanel>
                        <StackPanel Grid.Column="4" Grid.Row="0" Spacing="4">
                            <TextBlock Text="Time On" Foreground="White" FontSize="12" />
                            <TextBox Text="{Binding InputTimeOn}" Background="#2C3E50" Foreground="White" Padding="6" />
                        </StackPanel>
                        <StackPanel Grid.Column="5" Grid.Row="0" Spacing="4">
                            <TextBlock Text="Sent RST" Foreground="White" FontSize="12" />
                            <TextBox Text="{Binding InputSent}" Background="#2C3E50" Foreground="White" Padding="6" />
                        </StackPanel>

                        <!-- Row 2 -->
                        <StackPanel Grid.Column="0" Grid.Row="1" Spacing="4">
                            <TextBlock Text="Rec RST" Foreground="White" FontSize="12" />
                            <TextBox Text="{Binding InputRec}" Background="#2C3E50" Foreground="White" Padding="6" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="1" Spacing="4">
                            <TextBlock Text="Country" Foreground="White" FontSize="12" />
                            <TextBox Text="{Binding InputCountry}" Background="#2C3E50" Foreground="White" Padding="6" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Grid.Row="1" Spacing="4">
                            <TextBlock Text="Name" Foreground="White" FontSize="12" />
                            <TextBox Text="{Binding InputName}" Background="#2C3E50" Foreground="White" Padding="6" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Grid.Row="1" Spacing="4">
                            <TextBlock Text="State" Foreground="White" FontSize="12" />
                            <TextBox Text="{Binding InputState}" Background="#2C3E50" Foreground="White" Padding="6" />
                        </StackPanel>
                        <StackPanel Grid.Column="4" Grid.Row="1" Spacing="4">
                            <TextBlock Text="County" Foreground="White" FontSize="12" />
                            <TextBox Text="{Binding InputCounty}" Background="#2C3E50" Foreground="White" Padding="6" />
                        </StackPanel>
                        <StackPanel Grid.Column="5" Grid.Row="1" Spacing="4">
                            <TextBlock Text="Freq" Foreground="White" FontSize="12" />
                            <TextBox Text="{Binding InputFreq}" Background="#2C3E50" Foreground="White" Padding="6" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Comments" Foreground="White" FontSize="12" />
                        <TextBox Text="{Binding InputComments}" Background="#2C3E50" Foreground="White" Padding="6" Height="50" AcceptsReturn="True" TextWrapping="Wrap" />
                    </StackPanel>

                    <Button Content="Add Entry" Background="#3498DB" Foreground="White" Padding="8,6" Click="OnAddEntryClicked" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>




