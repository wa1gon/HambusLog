<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HamBusLog.Views.RigCatalogWindow"
        Title="Rig Catalog"
        Width="900"
        Height="560"
        MinWidth="640"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppForegroundBrush}">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" Margin="14">

        <!-- File picker bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
            <TextBlock Text="Rig List File:" VerticalAlignment="Center" />
            <TextBox Name="FilePathBox"
                     Text="{Binding FilePath}"
                     Watermark="Path to rigctld --list output file…"
                     Width="500"
                     IsReadOnly="True" />
            <Button Content="Browse…" Click="OnBrowseClicked" Padding="10,6" Background="{DynamicResource AppButtonCautionBrush}" Foreground="{DynamicResource AppButtonCautionForegroundBrush}" />
            <Button Content="Reload"  Click="OnReloadClicked" Padding="10,6" Background="{DynamicResource AppButtonCautionBrush}" Foreground="{DynamicResource AppButtonCautionForegroundBrush}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
            <TextBlock Text="Search Model:" VerticalAlignment="Center" />
            <TextBox Name="SearchModelBox"
                     Text="{Binding SearchModelText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Watermark="Type model to filter..."
                     Background="{DynamicResource AppPanelBackgroundBrush}"
                     Foreground="{DynamicResource AppForegroundBrush}"
                     CaretBrush="{DynamicResource AppForegroundBrush}"
                     Width="280" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
            <TextBlock Text="Serial Port:" VerticalAlignment="Center" />
            <ComboBox ItemsSource="{Binding AvailableSerialPorts}"
                      SelectedItem="{Binding SelectedSerialPort}"
                      Width="380"
                      IsEditable="True" />
            <Button Content="Refresh Ports" Click="OnRefreshSerialPortsClicked" Padding="10,6" Background="{DynamicResource AppButtonCautionBrush}" Foreground="{DynamicResource AppButtonCautionForegroundBrush}" />
        </StackPanel>

        <Grid Grid.Row="3" ColumnDefinitions="Auto,140,Auto,110,Auto,100,Auto,*" ColumnSpacing="8" Margin="0,0,0,10">
            <TextBlock Grid.Column="0" Text="Executable:" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding RigctldExecutable}" />
            <TextBlock Grid.Column="2" Text="Host:" VerticalAlignment="Center" />
            <TextBox Grid.Column="3" Text="{Binding RigctldHost}" />
            <TextBlock Grid.Column="4" Text="Port:" VerticalAlignment="Center" />
            <TextBox Grid.Column="5" Text="{Binding RigctldPort}" />
            <TextBlock Grid.Column="6" Text="Args:" VerticalAlignment="Center" />
            <TextBox Grid.Column="7"
                     Text="{Binding RigctldArgumentsTemplate}"
                     Watermark="-m {rigNum} -T {host} -t {port}{serialArg} ..." />
        </Grid>

        <!-- DataGrid -->
        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding FilteredEntries}"
                  SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                  SelectionMode="Extended"
                  SelectionChanged="OnSelectionChanged"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Rig #"   Binding="{Binding RigNum}"  Width="70" />
                <DataGridTextColumn Header="Mfg"     Binding="{Binding Mfg}"     Width="140" />
                <DataGridTextColumn Header="Model"   Binding="{Binding Model}"   Width="180" />
                <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="110" />
                <DataGridTextColumn Header="Status"  Binding="{Binding Status}"  Width="90" />
                <DataGridTextColumn Header="Macro"   Binding="{Binding Macro}"   Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="5" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Margin="0,8,0,0">
            <TextBlock Grid.Column="0" Text="rigctld Command:" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding RigctldCommandLine}"
                     IsReadOnly="True"
                     Margin="8,0,8,0"
                     FontFamily="Monospace" />
            <Button Grid.Column="2" Content="Copy Command" Click="OnCopyCommandClicked" Padding="10,6" Background="{DynamicResource AppButtonNormalBrush}" Foreground="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Grid>

        <!-- Status bar -->
        <TextBlock Grid.Row="6"
                   Text="{Binding StatusMessage}"
                   FontStyle="Italic"
                   Foreground="{DynamicResource AppAccentBrush}"
                   Margin="0,8,0,0" />
    </Grid>
</Window>
