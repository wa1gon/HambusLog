<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:HamBusLog.Views"
        x:Class="HamBusLog.Views.LogInputWindow"
        Title="New Log Entry"
        RequestedThemeVariant="Dark"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppForegroundBrush}"
        Width="860"
        Height="720"
        MinWidth="680"
        MinHeight="560"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <views:ContestTypeConverter x:Key="ContestTypeConverter" />
    </Window.Resources>
    <Window.Styles>
        <Style Selector="TextBlock.FieldLabel">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppMutedForegroundBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style Selector="TextBlock.SectionHeading">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Margin="16,12,16,12">

        <!-- ── Top Bar: Active Radio + Log Type ───────────────────────── -->
        <Border Grid.Row="0"
                Padding="12,10" Margin="0,0,0,10"
                CornerRadius="8"
                Background="{DynamicResource AppPanelBackgroundBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="16">

                <!-- Active Radio label + radio buttons -->
                <TextBlock Grid.Column="0"
                           Text="ACTIVE RADIO"
                           Classes="SectionHeading"
                           VerticalAlignment="Center"
                           Margin="0" />
                <ListBox Grid.Column="1"
                         ItemsSource="{Binding AvailableConnectedRadios}"
                         SelectedItem="{Binding SelectedConnectedRadio, Mode=TwoWay}"
                         Background="Transparent"
                         Foreground="{DynamicResource AppForegroundBrush}"
                         MinHeight="28"
                         MaxHeight="60"
                         BorderThickness="0"
                         Padding="0">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <RadioButton Content="{Binding Display}"
                                         GroupName="ConnectedRadios"
                                         Margin="0,0,16,0"
                                         FontSize="13"
                                         IsChecked="{Binding $parent[ListBoxItem].IsSelected, Mode=TwoWay}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Divider -->
                <Border Grid.Column="2" Width="1"
                        Background="{DynamicResource AppBorderBrush}"
                        VerticalAlignment="Stretch" Margin="0,2" />

                <!-- Log Type label -->
                <TextBlock Grid.Column="3"
                           Text="LOG TYPE"
                           Classes="SectionHeading"
                           VerticalAlignment="Center"
                           Margin="0" />

                <!-- Log Type combo -->
                <ComboBox Grid.Column="4"
                          ItemsSource="{Binding ContestTypes}"
                          SelectedItem="{Binding SelectedContestType}"
                          MinWidth="140"
                          VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource ContestTypeConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>
        </Border>

        <!-- ── Tab Panel ───────────────────────────────────────────────── -->
        <TabControl Grid.Row="1">

            <!-- Tab 1: Logging -->
            <TabItem Header="Logging">
                <ScrollViewer Padding="0,4,0,0">
                    <StackPanel Spacing="10" Margin="0,8,0,0">

                        <!-- QSO Fields Card -->
                        <Border Padding="16"
                                CornerRadius="8"
                                Background="{DynamicResource AppPanelBackgroundBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="0">
                                <TextBlock Text="QSO ENTRY" Classes="SectionHeading" />
                                <Grid ColumnDefinitions="1.2*,0.8*,0.8*,1.1*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">

                                    <!-- Row 1 -->
                                    <StackPanel Grid.Column="0" Grid.Row="0" Spacing="0">
                                        <TextBlock Text="CALLSIGN *" Classes="FieldLabel" />
                                        <TextBox Text="{Binding InputCall, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 TextChanged="OnUppercaseInputChanged"
                                                 Padding="8,7"
                                                 CornerRadius="5"
                                                 FontSize="14"
                                                 FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding CallError}" Foreground="{DynamicResource AppErrorBrush}" FontSize="11" IsVisible="{Binding HasCallError}" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Grid.Row="0" Spacing="0">
                                        <TextBlock Text="BAND *" Classes="FieldLabel" />
                                        <TextBox Text="{Binding InputBand}" Padding="8,7" CornerRadius="5" />
                                        <TextBlock Text="{Binding BandError}" Foreground="{DynamicResource AppErrorBrush}" FontSize="11" IsVisible="{Binding HasBandError}" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Grid.Row="0" Spacing="0">
                                        <TextBlock Text="MODE *" Classes="FieldLabel" />
                                        <TextBox Text="{Binding InputMode}" Padding="8,7" CornerRadius="5" />
                                        <TextBlock Text="{Binding ModeError}" Foreground="{DynamicResource AppErrorBrush}" FontSize="11" IsVisible="{Binding HasModeError}" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Grid.Row="0" Spacing="0">
                                        <TextBlock Text="FREQUENCY (MHz)" Classes="FieldLabel" />
                                        <TextBox Text="{Binding InputFreq}" Padding="8,7" CornerRadius="5" />
                                    </StackPanel>

                                    <!-- Row 2 -->
                                    <StackPanel Grid.Column="0" Grid.Row="1" Spacing="0">
                                        <TextBlock Text="DATE (YYYYMMDD)" Classes="FieldLabel" />
                                        <TextBox Text="{Binding InputDate}" Padding="8,7" CornerRadius="5" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Grid.Row="1" Spacing="0">
                                        <TextBlock Text="TIME ON (UTC)" Classes="FieldLabel" />
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBox Text="{Binding InputTimeOn}" Padding="8,7" CornerRadius="5" Width="80" />
                                            <Button Content="Now" Click="OnStampNowClicked"
                                                    Foreground="{DynamicResource AppButtonCautionForegroundBrush}"
                                                    Background="{DynamicResource AppButtonCautionBrush}"
                                                    Padding="10,7" CornerRadius="5" />
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Grid.Row="1" Spacing="0">
                                        <TextBlock Text="RST SENT" Classes="FieldLabel" />
                                        <TextBox Text="{Binding InputSent}" Padding="8,7" CornerRadius="5" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Grid.Row="1" Spacing="0">
                                        <TextBlock Text="RST RCVD" Classes="FieldLabel" />
                                        <TextBox Text="{Binding InputRec}" Padding="8,7" CornerRadius="5" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Field Day Exchange Card (conditional) -->
                        <Border IsVisible="{Binding IsFieldDay}"
                                Padding="16" CornerRadius="8"
                                BorderBrush="{DynamicResource AppWarningBrush}"
                                BorderThickness="1"
                                Background="{DynamicResource AppPanelBackgroundBrush}">
                            <StackPanel Spacing="0">
                                <TextBlock Text="FIELD DAY EXCHANGE"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource AppWarningBrush}"
                                           Margin="0,0,0,10" />
                                <Grid ColumnDefinitions="1*,1*" ColumnSpacing="10">
                                    <StackPanel Grid.Column="0" Spacing="0">
                                        <TextBlock Text="SECTION *" Classes="FieldLabel" />
                                        <TextBox Text="{Binding InputFieldDaySection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 TextChanged="OnUppercaseInputChanged"
                                                 Padding="8,7" CornerRadius="5" />
                                        <TextBlock Text="{Binding SectionError}" Foreground="{DynamicResource AppErrorBrush}" FontSize="11" IsVisible="{Binding HasSectionError}" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="0">
                                        <TextBlock Text="CLASS *" Classes="FieldLabel" />
                                        <TextBox Text="{Binding InputFieldDayClass, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 TextChanged="OnUppercaseInputChanged"
                                                 Padding="8,7" CornerRadius="5" />
                                        <TextBlock Text="{Binding ClassError}" Foreground="{DynamicResource AppErrorBrush}" FontSize="11" IsVisible="{Binding HasClassError}" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- QSO Details Card -->
                        <Border Padding="16" CornerRadius="8"
                                Background="{DynamicResource AppPanelBackgroundBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="CUSTOM FIELDS" Classes="SectionHeading" />
                                <Grid ColumnDefinitions="*,*,Auto,Auto" ColumnSpacing="6">
                                    <TextBox Grid.Column="0" Text="{Binding NewDetailField}" Watermark="Field name" Padding="8,7" CornerRadius="5" />
                                    <TextBox Grid.Column="1" Text="{Binding NewDetailValue}" Watermark="Value" Padding="8,7" CornerRadius="5" />
                                    <Button  Grid.Column="2" Content="Add"    Click="OnAddDetailClicked"
                                             Background="{DynamicResource AppButtonNormalBrush}"
                                             Foreground="{DynamicResource AppButtonNormalForegroundBrush}"
                                             Padding="12,7" CornerRadius="5" />
                                    <Button  Grid.Column="3" Content="Remove" Click="OnRemoveDetailClicked"
                                             Background="{DynamicResource AppButtonDangerBrush}"
                                             Foreground="{DynamicResource AppButtonDangerForegroundBrush}"
                                             Padding="12,7" CornerRadius="5" />
                                </Grid>
                                <DataGrid ItemsSource="{Binding Details}"
                                          SelectedItem="{Binding SelectedDetail, Mode=TwoWay}"
                                          IsReadOnly="False"
                                          AutoGenerateColumns="False"
                                          CanUserSortColumns="False"
                                          GridLinesVisibility="Horizontal"
                                          MinHeight="100"
                                          Background="{DynamicResource AppPanelBackgroundBrush}"
                                          Foreground="{DynamicResource AppForegroundBrush}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Field" Binding="{Binding FieldName}"  Width="200" IsReadOnly="False" />
                                        <DataGridTextColumn Header="Value" Binding="{Binding FieldValue}" Width="*"   IsReadOnly="False" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- ── Action bar ────────────────────────────────────────────────── -->
        <Border Grid.Row="2" Padding="0,10,0,0"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <Button Grid.Column="0"
                        Content="Log QSO"
                        Click="OnLogQsoClicked"
                        Background="{DynamicResource AppButtonNormalBrush}"
                        Foreground="{DynamicResource AppButtonNormalForegroundBrush}"
                        Padding="20,9" CornerRadius="6"
                        FontWeight="Bold" FontSize="13" />
                <TextBlock Grid.Column="1"
                           Name="StatusLabel"
                           Foreground="{DynamicResource AppErrorBrush}"
                           FontSize="12"
                           VerticalAlignment="Center" />
                <Button Grid.Column="2"
                        Content="Cancel"
                        Click="OnCancelClicked"
                        Background="Transparent"
                        Foreground="{DynamicResource AppMutedForegroundBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        Padding="16,9" CornerRadius="6" />
            </Grid>
        </Border>

    </Grid>
</Window>
