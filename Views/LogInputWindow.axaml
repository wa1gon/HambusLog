<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:HamBusLog.Views"
        x:Class="HamBusLog.Views.LogInputWindow"
        Title="New Contact"
        RequestedThemeVariant="Dark"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppForegroundBrush}"
        Width="860"
        Height="720"
        MinWidth="680"
        MinHeight="560"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <views:ContestTypeConverter x:Key="ContestTypeConverter" />
    </Window.Resources>
    <Window.Styles>
        <Style Selector="TextBlock.FieldLabel">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppMutedForegroundBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style Selector="TextBlock.SectionHeading">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Margin="16,12,16,12">

        <!-- ── Top Bar: Active Radio + Log Type ───────────────────────── -->
        <Border Grid.Row="0"
                Padding="12,10" Margin="0,0,0,10"
                CornerRadius="8"
                Background="{DynamicResource AppPanelBackgroundBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="16">

                <!-- Active Radio label + radio buttons -->
                <TextBlock Grid.Column="0"
                           Text="ACTIVE RADIO"
                           Classes="SectionHeading"
                           VerticalAlignment="Center"
                           Margin="0" />
                <ListBox Grid.Column="1"
                         ItemsSource="{Binding AvailableConnectedRadios}"
                         SelectedItem="{Binding SelectedConnectedRadio, Mode=TwoWay}"
                         Background="Transparent"
                         Foreground="{DynamicResource AppForegroundBrush}"
                         MinHeight="28"
                         MaxHeight="60"
                         BorderThickness="0"
                         Padding="0">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <RadioButton Content="{Binding Display}"
                                         GroupName="ConnectedRadios"
                                         Margin="0,0,16,0"
                                         FontSize="13"
                                         IsChecked="{Binding $parent[ListBoxItem].IsSelected, Mode=TwoWay}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Divider -->
                <Border Grid.Column="2" Width="1"
                        Background="{DynamicResource AppBorderBrush}"
                        VerticalAlignment="Stretch" Margin="0,2" />

                <!-- Log Type label -->
                <TextBlock Grid.Column="3"
                           Text="LOG TYPE"
                           Classes="SectionHeading"
                           VerticalAlignment="Center"
                           Margin="0" />

                <!-- Log Type combo -->
                <ComboBox Grid.Column="4"
                          ItemsSource="{Binding ContestDefinitions}"
                          SelectedItem="{Binding SelectedContestDefinition}"
                          MinWidth="140"
                          VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>
        </Border>


        <!-- ── Contact entry cards ────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
                <Border Padding="12"
                        CornerRadius="8"
                        Background="{DynamicResource AppPanelBackgroundBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1">
                    <Grid ColumnDefinitions="Auto,170,16,Auto,170"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                          RowSpacing="10">
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="5"
                                   Classes="SectionHeading"
                                   Text="REQUIRED FIELDS" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Classes="FieldLabel" Text="Call" VerticalAlignment="Center" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding InputCall}"
                                 Watermark="K1ABC"
                                 TextChanged="OnUppercaseInputChanged" />

                        <TextBlock Grid.Row="1" Grid.Column="3" Classes="FieldLabel" Text="Date (YYYYMMDD)" VerticalAlignment="Center" />
                        <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding InputDate}" Watermark="20260504" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Classes="FieldLabel" Text="Time On (HHMM)" VerticalAlignment="Center" />
                        <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <TextBox Grid.Column="0" Text="{Binding InputTimeOn}" Watermark="1930" />
                            <Button Grid.Column="1" Content="Now" Click="OnStampNowClicked" Padding="10,6" />
                        </Grid>

                        <TextBlock Grid.Row="2" Grid.Column="3" Classes="FieldLabel" Text="Frequency (MHz)" VerticalAlignment="Center" />
                        <TextBox Grid.Row="2" Grid.Column="4" Text="{Binding InputFreq}" Watermark="14.250" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Classes="FieldLabel" Text="Band" VerticalAlignment="Center" />
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding InputBand}" Watermark="20M" />

                        <TextBlock Grid.Row="3" Grid.Column="3" Classes="FieldLabel" Text="Mode" VerticalAlignment="Center" />
                        <TextBox Grid.Row="3" Grid.Column="4" Text="{Binding InputMode}" Watermark="SSB" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="5"
                                   Text="These are always required for every log entry."
                                   Foreground="{DynamicResource AppMutedForegroundBrush}"
                                   FontSize="11" />
                    </Grid>
                </Border>

                <Border Padding="12"
                        CornerRadius="8"
                        Background="{DynamicResource AppPanelBackgroundBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1">
                    <Grid ColumnDefinitions="Auto,170,16,Auto,170"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                          RowSpacing="10">
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="5"
                                   Classes="SectionHeading"
                                   Text="CONTEST REQUIREMENTS" />

                        <TextBlock Grid.Row="1" Grid.ColumnSpan="5"
                                   Text="{Binding CurrentContestDisplayName, StringFormat=Selected: {0}}"
                                   Foreground="{DynamicResource AppMutedForegroundBrush}"
                                   FontSize="11" />
                        <TextBlock Grid.Row="1" Grid.Column="4"
                                   HorizontalAlignment="Right"
                                   Text="{Binding CurrentContestAdifId, StringFormat=ADIF: {0}}"
                                   Foreground="{DynamicResource AppMutedForegroundBrush}"
                                   FontSize="11" />

                        <TextBlock Grid.Row="2" Grid.ColumnSpan="5"
                                   IsVisible="{Binding IsNormalContest}"
                                   Text="Normal Contest Required Exchange"
                                   Foreground="{DynamicResource AppMutedForegroundBrush}"
                                   FontSize="11" />

                        <TextBlock Grid.Row="3" Grid.Column="0" IsVisible="{Binding IsNormalContest}" Classes="FieldLabel" Text="RST Sent" VerticalAlignment="Center" />
                        <TextBox Grid.Row="3" Grid.Column="1" IsVisible="{Binding IsNormalContest}" Text="{Binding InputSent}" Watermark="59" />

                        <TextBlock Grid.Row="3" Grid.Column="3" IsVisible="{Binding IsNormalContest}" Classes="FieldLabel" Text="RST Rec" VerticalAlignment="Center" />
                        <TextBox Grid.Row="3" Grid.Column="4" IsVisible="{Binding IsNormalContest}" Text="{Binding InputRec}" Watermark="59" />

                        <TextBlock Grid.Row="4" Grid.Column="0" IsVisible="{Binding IsNormalContest}" Classes="FieldLabel" Text="Country" VerticalAlignment="Center" />
                        <TextBox Grid.Row="4" Grid.Column="1" IsVisible="{Binding IsNormalContest}" Text="{Binding InputCountry}" Watermark="USA" TextChanged="OnUppercaseInputChanged" />

                        <TextBlock Grid.Row="4" Grid.Column="3" IsVisible="{Binding IsNormalContest}" Classes="FieldLabel" Text="Name" VerticalAlignment="Center" />
                        <TextBox Grid.Row="4" Grid.Column="4" IsVisible="{Binding IsNormalContest}" Text="{Binding InputName}" Watermark="Darryl" />

                        <TextBlock Grid.Row="5" Grid.Column="0" IsVisible="{Binding IsNormalContest}" Classes="FieldLabel" Text="State" VerticalAlignment="Center" />
                        <TextBox Grid.Row="5" Grid.Column="1" IsVisible="{Binding IsNormalContest}" Text="{Binding InputState}" Watermark="MA" TextChanged="OnUppercaseInputChanged" />

                        <TextBlock Grid.Row="5" Grid.Column="3" IsVisible="{Binding IsNormalContest}" Classes="FieldLabel" Text="County" VerticalAlignment="Center" />
                        <TextBox Grid.Row="5" Grid.Column="4" IsVisible="{Binding IsNormalContest}" Text="{Binding InputCounty}" Watermark="MIDDLESEX" TextChanged="OnUppercaseInputChanged" />

                        <TextBlock Grid.Row="2" Grid.ColumnSpan="5"
                                   IsVisible="{Binding IsFieldDay}"
                                   Text="Field Day Required Exchange"
                                   Foreground="{DynamicResource AppMutedForegroundBrush}"
                                   FontSize="11" />

                        <TextBlock Grid.Row="3" Grid.Column="0" IsVisible="{Binding IsFieldDay}" Classes="FieldLabel" Text="Field Day Section" VerticalAlignment="Center" />
                        <TextBox Grid.Row="3" Grid.Column="1"
                                 IsVisible="{Binding IsFieldDay}"
                                 Text="{Binding InputFieldDaySection}"
                                 Watermark="EMA"
                                 TextChanged="OnUppercaseInputChanged" />

                        <TextBlock Grid.Row="3" Grid.Column="3" IsVisible="{Binding IsFieldDay}" Classes="FieldLabel" Text="Field Day Class" VerticalAlignment="Center" />
                        <TextBox Grid.Row="3" Grid.Column="4"
                                 IsVisible="{Binding IsFieldDay}"
                                 Text="{Binding InputFieldDayClass}"
                                 Watermark="1D"
                                 TextChanged="OnUppercaseInputChanged" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="5"
                                   IsVisible="{Binding HasContestError}"
                                   Text="{Binding ContestError}"
                                   Foreground="{DynamicResource AppErrorBrush}"
                                   FontSize="11" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="5"
                                   IsVisible="{Binding !HasContestError}"
                                   Text="Card #2 changes based on selected Log Type."
                                   Foreground="{DynamicResource AppMutedForegroundBrush}"
                                   FontSize="11" />
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ── Action bar ────────────────────────────────────────────────── -->
        <Border Grid.Row="2" Padding="0,10,0,0"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <Button Grid.Column="0"
                        Content="Log QSO"
                        Click="OnLogQsoClicked"
                        Background="{DynamicResource AppButtonNormalBrush}"
                        Foreground="{DynamicResource AppButtonNormalForegroundBrush}"
                        Padding="20,9" CornerRadius="6"
                        FontWeight="Bold" FontSize="13" />
                <TextBlock Grid.Column="1"
                           Name="StatusLabel"
                           Foreground="{DynamicResource AppErrorBrush}"
                           FontSize="12"
                           VerticalAlignment="Center" />
                <Button Grid.Column="2"
                        Content="Cancel"
                        Click="OnCancelClicked"
                        Background="Transparent"
                        Foreground="{DynamicResource AppMutedForegroundBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        Padding="16,9" CornerRadius="6" />
            </Grid>
        </Border>

    </Grid>
</Window>
