<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:HamBusLog.Views"
        x:Class="HamBusLog.Views.LogInputWindow"
        Title="New Log Entry"
        RequestedThemeVariant="Dark"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppForegroundBrush}"
        Width="860"
        Height="720"
        MinWidth="640"
        MinHeight="540"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <views:ContestTypeConverter x:Key="ContestTypeConverter" />
    </Window.Resources>
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="14">

        <!-- ── Active Radio row (above everything) ─────────────────────── -->
        <Border Grid.Row="0" Padding="10" Margin="0,0,0,8"
                CornerRadius="6"
                Background="{DynamicResource AppPanelBackgroundBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <TextBlock Grid.Column="0"
                           Text="Active Radio"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppForegroundBrush}" />
                <ListBox Grid.Column="1"
                         ItemsSource="{Binding AvailableConnectedRadios}"
                         SelectedItem="{Binding SelectedConnectedRadio, Mode=TwoWay}"
                         Background="Transparent"
                         Foreground="{DynamicResource AppForegroundBrush}"
                         MinHeight="34"
                         MaxHeight="70"
                         BorderThickness="0">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <RadioButton Content="{Binding Display}"
                                         GroupName="ConnectedRadios"
                                         Margin="0,0,12,0"
                                         IsChecked="{Binding $parent[ListBoxItem].IsSelected, Mode=TwoWay}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ── Log Type (outside tabs for visibility) ──────────────────── -->
        <Border Grid.Row="1" Padding="10" Margin="0,0,0,8"
                CornerRadius="6"
                Background="{DynamicResource AppPanelBackgroundBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1">
            <Grid ColumnDefinitions="160,*" ColumnSpacing="8">
                <TextBlock Grid.Column="0"
                           Text="Log Type"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppForegroundBrush}" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding ContestTypes}"
                          SelectedItem="{Binding SelectedContestType}"
                          Background="{DynamicResource AppPanelBackgroundBrush}"
                          Foreground="{DynamicResource AppForegroundBrush}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource ContestTypeConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>
        </Border>

        <!-- ── Tab Panel ───────────────────────────────────────────────── -->
        <TabControl Grid.Row="2">

            <!-- Tab 1: Logging -->
            <TabItem Header="Logging">
                <ScrollViewer>
                    <StackPanel Spacing="12" Margin="0,8,0,0">
                        <TextBlock Text="New QSO" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppForegroundBrush}" />

                        <Grid ColumnDefinitions="1*,1*,1*,1*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                            <StackPanel Grid.Column="0" Grid.Row="0" Spacing="3">
                                <TextBlock Text="Callsign *" Foreground="{DynamicResource AppForegroundBrush}" FontSize="12" FontWeight="Bold" />
                                <TextBox Text="{Binding InputCall, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         TextChanged="OnUppercaseInputChanged"
                                         Background="{DynamicResource AppPanelBackgroundBrush}"
                                         Foreground="{DynamicResource AppForegroundBrush}"
                                         Padding="6" />
                                <TextBlock Text="{Binding CallError}" Foreground="{DynamicResource AppErrorBrush}" FontSize="11" IsVisible="{Binding HasCallError}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="0" Spacing="3">
                                <TextBlock Text="Band *" Foreground="{DynamicResource AppForegroundBrush}" FontSize="12" FontWeight="Bold" />
                                <TextBox Text="{Binding InputBand}" Background="{DynamicResource AppPanelBackgroundBrush}" Foreground="{DynamicResource AppForegroundBrush}" Padding="6" />
                                <TextBlock Text="{Binding BandError}" Foreground="{DynamicResource AppErrorBrush}" FontSize="11" IsVisible="{Binding HasBandError}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Grid.Row="0" Spacing="3">
                                <TextBlock Text="Mode *" Foreground="{DynamicResource AppForegroundBrush}" FontSize="12" FontWeight="Bold" />
                                <TextBox Text="{Binding InputMode}" Background="{DynamicResource AppPanelBackgroundBrush}" Foreground="{DynamicResource AppForegroundBrush}" Padding="6" />
                                <TextBlock Text="{Binding ModeError}" Foreground="{DynamicResource AppErrorBrush}" FontSize="11" IsVisible="{Binding HasModeError}" />
                            </StackPanel>
                            <StackPanel Grid.Column="3" Grid.Row="0" Spacing="3">
                                <TextBlock Text="Frequency (MHz)" Foreground="{DynamicResource AppForegroundBrush}" FontSize="12" />
                                <TextBox Text="{Binding InputFreq}" Background="{DynamicResource AppPanelBackgroundBrush}" Foreground="{DynamicResource AppForegroundBrush}" Padding="6" />
                            </StackPanel>
                            <StackPanel Grid.Column="0" Grid.Row="1" Spacing="3">
                                <TextBlock Text="Date (YYYYMMDD)" Foreground="{DynamicResource AppForegroundBrush}" FontSize="12" />
                                <TextBox Text="{Binding InputDate}" Background="{DynamicResource AppPanelBackgroundBrush}" Foreground="{DynamicResource AppForegroundBrush}" Padding="6" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="1" Spacing="3">
                                <TextBlock Text="Time On (HHMM UTC)" Foreground="{DynamicResource AppForegroundBrush}" FontSize="12" />
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBox Text="{Binding InputTimeOn}" Background="{DynamicResource AppPanelBackgroundBrush}" Foreground="{DynamicResource AppForegroundBrush}" Padding="6" Width="80" />
                                    <Button Content="Now" Click="OnStampNowClicked" Foreground="{DynamicResource AppButtonCautionForegroundBrush}" Background="{DynamicResource AppButtonCautionBrush}" Padding="6,4" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Grid.Row="1" Spacing="3">
                                <TextBlock Text="RST Sent" Foreground="{DynamicResource AppForegroundBrush}" FontSize="12" />
                                <TextBox Text="{Binding InputSent}" Background="{DynamicResource AppPanelBackgroundBrush}" Foreground="{DynamicResource AppForegroundBrush}" Padding="6" />
                            </StackPanel>
                            <StackPanel Grid.Column="3" Grid.Row="1" Spacing="3">
                                <TextBlock Text="RST Rcvd" Foreground="{DynamicResource AppForegroundBrush}" FontSize="12" />
                                <TextBox Text="{Binding InputRec}" Background="{DynamicResource AppPanelBackgroundBrush}" Foreground="{DynamicResource AppForegroundBrush}" Padding="6" />
                            </StackPanel>
                        </Grid>

                        <!-- Field Day exchange -->
                        <StackPanel IsVisible="{Binding IsFieldDay}" Spacing="8">
                            <TextBlock Text="Field Day Exchange" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource AppWarningBrush}" />
                            <Grid ColumnDefinitions="1*,1*" ColumnSpacing="8">
                                <StackPanel Grid.Column="0" Spacing="3">
                                    <TextBlock Text="Section *" Foreground="{DynamicResource AppForegroundBrush}" FontSize="12" />
                                    <TextBox Text="{Binding InputFieldDaySection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             TextChanged="OnUppercaseInputChanged"
                                             Background="{DynamicResource AppPanelBackgroundBrush}"
                                             Foreground="{DynamicResource AppForegroundBrush}"
                                             Padding="6" />
                                    <TextBlock Text="{Binding SectionError}" Foreground="{DynamicResource AppErrorBrush}" FontSize="11" IsVisible="{Binding HasSectionError}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="3">
                                    <TextBlock Text="Class *" Foreground="{DynamicResource AppForegroundBrush}" FontSize="12" />
                                    <TextBox Text="{Binding InputFieldDayClass, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             TextChanged="OnUppercaseInputChanged"
                                             Background="{DynamicResource AppPanelBackgroundBrush}"
                                             Foreground="{DynamicResource AppForegroundBrush}"
                                             Padding="6" />
                                    <TextBlock Text="{Binding ClassError}" Foreground="{DynamicResource AppErrorBrush}" FontSize="11" IsVisible="{Binding HasClassError}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <TextBlock Text="QSO Details (custom fields)" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource AppForegroundBrush}" Margin="0,8,0,0" />
                        <Grid ColumnDefinitions="*,*,Auto,Auto" ColumnSpacing="6">
                            <TextBox Grid.Column="0" Text="{Binding NewDetailField}" Watermark="Field name" Background="{DynamicResource AppPanelBackgroundBrush}" Foreground="{DynamicResource AppForegroundBrush}" Padding="6" />
                            <TextBox Grid.Column="1" Text="{Binding NewDetailValue}" Watermark="Value"      Background="{DynamicResource AppPanelBackgroundBrush}" Foreground="{DynamicResource AppForegroundBrush}" Padding="6" />
                            <Button  Grid.Column="2" Content="Add"    Click="OnAddDetailClicked"    Background="{DynamicResource AppButtonNormalBrush}" Foreground="{DynamicResource AppButtonNormalForegroundBrush}" Padding="10,6" />
                            <Button  Grid.Column="3" Content="Remove" Click="OnRemoveDetailClicked" Background="{DynamicResource AppButtonDangerBrush}" Foreground="{DynamicResource AppButtonDangerForegroundBrush}" Padding="10,6" />
                        </Grid>
                        <DataGrid ItemsSource="{Binding Details}"
                                  SelectedItem="{Binding SelectedDetail, Mode=TwoWay}"
                                  IsReadOnly="False"
                                  AutoGenerateColumns="False"
                                  CanUserSortColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  MinHeight="120"
                                  Background="{DynamicResource AppPanelBackgroundBrush}"
                                  Foreground="{DynamicResource AppForegroundBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Field" Binding="{Binding FieldName}"  Width="200" IsReadOnly="False" />
                                <DataGridTextColumn Header="Value" Binding="{Binding FieldValue}" Width="*"   IsReadOnly="False" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 2: Station Configuration -->
            <TabItem Header="Station Config">
                <ScrollViewer>
                    <StackPanel Spacing="12" Margin="0,8,0,0">
                        <TextBlock Text="Station Configuration" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppForegroundBrush}" />

                        <!-- My Callsign (always shown) -->
                        <StackPanel Spacing="3">
                            <TextBlock Text="My Callsign" Foreground="{DynamicResource AppForegroundBrush}" FontSize="12" FontWeight="Bold" />
                            <TextBox Text="{Binding MyCall, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     TextChanged="OnUppercaseInputChanged"
                                     Background="{DynamicResource AppPanelBackgroundBrush}"
                                     Foreground="{DynamicResource AppForegroundBrush}"
                                     Padding="6" />
                        </StackPanel>

                        <!-- Field Day fields (shown only when Field Day log type selected) -->
                        <StackPanel IsVisible="{Binding IsFieldDay}" Spacing="8">
                            <TextBlock Text="Field Day Station Info" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource AppWarningBrush}" />
                            <StackPanel Spacing="3">
                                <TextBlock Text="My Section" Foreground="{DynamicResource AppForegroundBrush}" FontSize="12" />
                                <TextBox Text="{Binding MyFieldDaySection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         TextChanged="OnUppercaseInputChanged"
                                         Background="{DynamicResource AppPanelBackgroundBrush}"
                                         Foreground="{DynamicResource AppForegroundBrush}"
                                         Padding="6" Width="200" HorizontalAlignment="Left" />
                            </StackPanel>
                            <StackPanel Spacing="3">
                                <TextBlock Text="My Class" Foreground="{DynamicResource AppForegroundBrush}" FontSize="12" />
                                <TextBox Text="{Binding MyFieldDayClass, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         TextChanged="OnUppercaseInputChanged"
                                         Background="{DynamicResource AppPanelBackgroundBrush}"
                                         Foreground="{DynamicResource AppForegroundBrush}"
                                         Padding="6" Width="160" HorizontalAlignment="Left" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Normal/General station fields (shown when not Field Day) -->
                        <StackPanel IsVisible="{Binding !IsFieldDay}" Spacing="8">
                            <TextBlock Text="Station Location" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource AppForegroundBrush}" />
                            <Grid ColumnDefinitions="1*,1*" ColumnSpacing="8">
                                <StackPanel Grid.Column="0" Spacing="3">
                                    <TextBlock Text="Latitude" Foreground="{DynamicResource AppForegroundBrush}" FontSize="12" />
                                    <TextBox Text="{Binding MyLatitude, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Watermark="e.g. 42.3601"
                                             Background="{DynamicResource AppPanelBackgroundBrush}"
                                             Foreground="{DynamicResource AppForegroundBrush}"
                                             Padding="6" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="3">
                                    <TextBlock Text="Longitude" Foreground="{DynamicResource AppForegroundBrush}" FontSize="12" />
                                    <TextBox Text="{Binding MyLongitude, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Watermark="e.g. -71.0589"
                                             Background="{DynamicResource AppPanelBackgroundBrush}"
                                             Foreground="{DynamicResource AppForegroundBrush}"
                                             Padding="6" />
                                </StackPanel>
                            </Grid>
                            <Grid ColumnDefinitions="1*,1*,1*" ColumnSpacing="8">
                                <StackPanel Grid.Column="0" Spacing="3">
                                    <TextBlock Text="Grid Square" Foreground="{DynamicResource AppForegroundBrush}" FontSize="12" />
                                    <TextBox Text="{Binding MyGridSquare, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Watermark="e.g. FN42"
                                             Background="{DynamicResource AppPanelBackgroundBrush}"
                                             Foreground="{DynamicResource AppForegroundBrush}"
                                             Padding="6" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="3">
                                    <TextBlock Text="ITU Zone" Foreground="{DynamicResource AppForegroundBrush}" FontSize="12" />
                                    <TextBox Text="{Binding MyItuZone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Watermark="e.g. 8"
                                             Background="{DynamicResource AppPanelBackgroundBrush}"
                                             Foreground="{DynamicResource AppForegroundBrush}"
                                             Padding="6" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="3">
                                    <TextBlock Text="CQ Zone" Foreground="{DynamicResource AppForegroundBrush}" FontSize="12" />
                                    <TextBox Text="{Binding MyCqZone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Watermark="e.g. 5"
                                             Background="{DynamicResource AppPanelBackgroundBrush}"
                                             Foreground="{DynamicResource AppForegroundBrush}"
                                             Padding="6" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- ── Action buttons ───────────────────────────────────────────── -->
        <Border Grid.Row="3" Padding="0,10,0,2" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Log QSO"  Click="OnLogQsoClicked"  Background="{DynamicResource AppButtonNormalBrush}" Foreground="{DynamicResource AppButtonNormalForegroundBrush}" Padding="16,8" FontWeight="Bold" />
                    <Button Content="Cancel"   Click="OnCancelClicked"  Background="{DynamicResource AppButtonCautionBrush}" Foreground="{DynamicResource AppButtonCautionForegroundBrush}" Padding="16,8" />
                </StackPanel>
                <TextBlock Name="StatusLabel" Foreground="{DynamicResource AppErrorBrush}" FontSize="12" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
