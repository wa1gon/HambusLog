<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HamBusLog.Views.SettingsWindow"
        Title="Configuration"
        Width="800"
        Height="650"
        MinWidth="600"
        MinHeight="520"
        WindowStartupLocation="CenterOwner">
    <ScrollViewer>
        <StackPanel Margin="16" Spacing="12">
            <TextBlock Text="Configuration" FontSize="24" FontWeight="Bold" />

            <!-- Profile Selection -->
            <Grid ColumnDefinitions="200,*" RowDefinitions="Auto" RowSpacing="8" ColumnSpacing="8">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Profile" VerticalAlignment="Center" />
                <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding AvailableProfiles}" SelectedItem="{Binding SelectedProfile}" />
            </Grid>

            <!-- Settings -->
            <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="12" ColumnSpacing="8">
                <!-- Background Color -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Background Color" VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding BackgroundColor}" Watermark="#1F2937" />

                <!-- Foreground Color -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Foreground Color" VerticalAlignment="Center" />
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ForegroundColor}" Watermark="#FFFFFF" />

                <!-- Connection String -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Connection String" VerticalAlignment="Center" />
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ConnectionString}" Watermark="Server=...;Database=...;" />

                <!-- rigctld Host -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="rigctld Host" VerticalAlignment="Center" />
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding RigctldHost}" />

                <!-- rigctld Port -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="rigctld Port" VerticalAlignment="Center" />
                <NumericUpDown Grid.Row="4" Grid.Column="1" Minimum="1" Maximum="65535" Value="{Binding RigctldPort}" HorizontalAlignment="Left" Width="150" />

                <!-- Config File Path -->
                <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding ConfigFilePath}" FontSize="11" Foreground="#7F8C8D" IsVisible="{Binding !!ConfigFilePath}" />

                <!-- Status Message -->
                <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding StatusMessage}" FontStyle="Italic" Foreground="#3498DB" />
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                <Button Content="Save" Click="OnSaveClicked" Padding="14,8" />
                <Button Content="Close" Click="OnCloseClicked" Padding="14,8" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>

