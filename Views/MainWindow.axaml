<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HamBusLog.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="HamBusLog.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="1200"
        Height="760"
        MinWidth="980"
        MinHeight="620"
        Title="HamBusLog"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppForegroundBrush}">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="220,*">
        <Border Grid.Column="0" Background="{DynamicResource AppMenuBackgroundBrush}" Padding="12">
            <StackPanel Spacing="10">
                <TextBlock Text="Menu" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppMenuForegroundBrush}" Margin="4,2,4,8"/>
                <TreeView ItemsSource="{Binding MenuItems}"
                          SelectedItem="{Binding SelectedMenuItem, Mode=TwoWay}"
                          Foreground="{DynamicResource AppMenuForegroundBrush}"
                          Background="Transparent"
                          BorderThickness="0"
                          Name="MenuTreeView"
                          SelectionChanged="OnMenuTreeViewSelectionChanged"
                          >
                    <TreeView.Styles>
                        <Style Selector="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{ReflectionBinding DataContext.IsExpanded, RelativeSource={RelativeSource Self}, Mode=TwoWay}"/>
                        </Style>
                    </TreeView.Styles>
                    <TreeView.ItemTemplate>
                        <TreeDataTemplate x:DataType="vm:MenuNode" ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Title}" Foreground="{DynamicResource AppMenuForegroundBrush}"/>
                        </TreeDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

            </StackPanel>
        </Border>

        <Border Grid.Column="1" Padding="20" Background="{DynamicResource AppWindowBackgroundBrush}">
            <StackPanel Spacing="12">
                <TextBlock Text="HamBusLog" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AppForegroundBrush}"/>
                <TextBlock Text="{Binding SelectedMenuTitle, StringFormat=Selected: {0}}" FontSize="16" Foreground="{DynamicResource AppForegroundBrush}"/>

                <Border Background="{DynamicResource AppPanelBackgroundBrush}" CornerRadius="6" Padding="10" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Rigctld Radios" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding RadioStatusSummary}" TextWrapping="Wrap"/>
                        <!-- Radio status table -->
                        <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="4">
                            <StackPanel>
                                <!-- Header row -->
                                <Grid ColumnDefinitions="40,150,70,70,100,70,*" Background="#1A1A2E">
                                    <TextBlock Grid.Column="0" Text="#"      Foreground="#AAAAAA" FontWeight="SemiBold" Margin="6,4"/>
                                    <TextBlock Grid.Column="1" Text="Name"   Foreground="#AAAAAA" FontWeight="SemiBold" Margin="6,4"/>
                                    <TextBlock Grid.Column="2" Text="Model #" Foreground="#AAAAAA" FontWeight="SemiBold" Margin="6,4"/>
                                    <TextBlock Grid.Column="3" Text="Port"   Foreground="#AAAAAA" FontWeight="SemiBold" Margin="6,4"/>
                                    <TextBlock Grid.Column="4" Text="Freq"   Foreground="#AAAAAA" FontWeight="SemiBold" Margin="6,4"/>
                                    <TextBlock Grid.Column="5" Text="Mode"   Foreground="#AAAAAA" FontWeight="SemiBold" Margin="6,4"/>
                                    <TextBlock Grid.Column="6" Text="Status" Foreground="#AAAAAA" FontWeight="SemiBold" Margin="6,4"/>
                                </Grid>
                                <Rectangle Height="1" Fill="{DynamicResource AppBorderBrush}"/>
                                <!-- Data rows -->
                                <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding RadioStatuses}">
                                        <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:RadioConnectionStatusViewModel">
                                                    <Border Padding="0" BorderThickness="0,0,0,1"
                                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                                            Background="{Binding RowBackground}"
                                                            PointerPressed="OnRadioRowPointerPressed">
                                                        <Grid ColumnDefinitions="40,150,70,70,100,70,*">
                                                            <TextBlock Grid.Column="0" Text="{Binding RowNumber}" Foreground="{Binding RowForeground}" Margin="6,5"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Label}"     Foreground="{Binding RowForeground}" Margin="6,5"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding RigModel}"  Foreground="{Binding RowForeground}" Margin="6,5"/>
                                                            <TextBlock Grid.Column="3" Text="{Binding ListenPort}" Foreground="{Binding RowForeground}" Margin="6,5"/>
                                                            <TextBlock Grid.Column="4" Text="{Binding Frequency}" Foreground="{Binding RowForeground}" Margin="6,5"/>
                                                            <TextBlock Grid.Column="5" Text="{Binding Mode}"      Foreground="{Binding RowForeground}" Margin="6,5"/>
                                                            <TextBlock Grid.Column="6" Text="{Binding Status}"    Foreground="{Binding RowForeground}" Margin="6,5" TextWrapping="NoWrap"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <!-- Radio selector and controls -->
                        <Grid ColumnDefinitions="Auto,*,Auto,160,Auto,140,Auto">
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Control Radio:" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding RadioStatuses}"
                                      SelectedItem="{Binding SelectedRadioStatus, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      Margin="0,0,16,0">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:RadioConnectionStatusViewModel">
                                        <TextBlock Text="{Binding Label}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Freq MHz:" Margin="0,0,8,0"
                                       IsEnabled="{Binding CanControlSelectedRadio}"/>
                            <TextBox Grid.Column="3" Text="{Binding ControlFrequencyMhz, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Watermark="14.074" IsEnabled="{Binding CanControlSelectedRadio}"/>
                            <Button Grid.Column="4" Margin="8,0,12,0" Content="Apply"
                                    IsEnabled="{Binding CanControlSelectedRadio}" Click="OnApplyRadioFrequencyClick"/>
                            <TextBox Grid.Column="5" Text="{Binding ControlMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Watermark="USB" IsEnabled="{Binding CanControlSelectedRadio}"/>
                            <Button Grid.Column="6" HorizontalAlignment="Left" Margin="8,0,0,0" Content="Apply Mode"
                                    IsEnabled="{Binding CanControlSelectedRadio}" Click="OnApplyRadioModeClick"/>
                        </Grid>

                        <WrapPanel IsEnabled="{Binding CanControlSelectedRadio}" ItemHeight="30">
                            <Button Content="USB"  Tag="USB"  MinWidth="58" Margin="0,0,4,4" Click="OnApplyPresetModeClick"/>
                            <Button Content="LSB"  Tag="LSB"  MinWidth="58" Margin="0,0,4,4" Click="OnApplyPresetModeClick"/>
                            <Button Content="CW"   Tag="CW"   MinWidth="58" Margin="0,0,4,4" Click="OnApplyPresetModeClick"/>
                            <Button Content="AM"   Tag="AM"   MinWidth="58" Margin="0,0,4,4" Click="OnApplyPresetModeClick"/>
                            <Button Content="FM"   Tag="FM"   MinWidth="58" Margin="0,0,4,4" Click="OnApplyPresetModeClick"/>
                            <Button Content="DIGU" Tag="DIGU" MinWidth="64" Margin="0,0,4,4" Click="OnApplyPresetModeClick"/>
                            <Button Content="DIGL" Tag="DIGL" MinWidth="64" Margin="0,0,4,4" Click="OnApplyPresetModeClick"/>
                        </WrapPanel>

                        <TextBlock Text="{Binding RadioControlMessage}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>

</Window>
