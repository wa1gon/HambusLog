<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HamBusLog.App"
             xmlns:local="using:HamBusLog"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="AppPanelBackgroundBrush" Color="#2C3E50" />
        <SolidColorBrush x:Key="AppHeaderBackgroundBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="AppForegroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AppMutedForegroundBrush" Color="#9CA3AF" />
        <SolidColorBrush x:Key="AppBorderBrush" Color="#34495E" />
        <SolidColorBrush x:Key="AppAccentBrush" Color="#3498DB" />
        <SolidColorBrush x:Key="AppErrorBrush" Color="#FF6B6B" />
        <SolidColorBrush x:Key="AppWarningBrush" Color="#FFD700" />
    </Application.Resources>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml"/>
    </Application.Styles>
</Application>