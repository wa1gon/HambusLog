<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HamBusLog.App"
             xmlns:local="using:HamBusLog"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="AppPanelBackgroundBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="AppHeaderBackgroundBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="AppMenuBackgroundBrush" Color="#111827" />
        <SolidColorBrush x:Key="AppMenuForegroundBrush" Color="#F9FAFB" />
        <SolidColorBrush x:Key="AppForegroundBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="AppMutedForegroundBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="NBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="AppBorderBrush" Color="#334155" />
        <SolidColorBrush x:Key="AppAccentBrush" Color="#3498DB" />
        <SolidColorBrush x:Key="AppButtonNormalBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="AppButtonNormalForegroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AppButtonCautionBrush" Color="#B45309" />
        <SolidColorBrush x:Key="AppButtonCautionForegroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AppButtonDangerBrush" Color="#B91C1C" />
        <SolidColorBrush x:Key="AppButtonDangerForegroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AppButtonForegroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AppErrorBrush" Color="#FF6B6B" />
        <SolidColorBrush x:Key="AppWarningBrush" Color="#FFD700" />

        <!-- Fluent text-input palette overrides for high contrast across normal/focus/selection states -->
        <SolidColorBrush x:Key="TextControlBackground" Color="#1F2937" />
        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#334155" />
        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#1F2937" />
        <SolidColorBrush x:Key="TextControlForeground" Color="#F9FAFB" />
        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#F9FAFB" />
        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#F9FAFB" />
        <SolidColorBrush x:Key="TextControlBorderBrush" Color="#334155" />
        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#3498DB" />
        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#3498DB" />
        <SolidColorBrush x:Key="TextControlSelectionBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="TextControlSelectionForegroundBrush" Color="#FFFFFF" />
        <Color x:Key="TextControlSelectionHighlightColor">#1D4ED8</Color>
        <Color x:Key="TextControlSelectionHighlightColorWhenNotFocused">#1D4ED8</Color>
        <SolidColorBrush x:Key="ActiveControlBackgroundBrush" Color="#4A90E2" />
        <SolidColorBrush x:Key="ActiveControlForegroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ActiveControlBorderBrush" Color="#007AFF" />
        <x:Double x:Key="AppBaseFontSize">12</x:Double>

    </Application.Resources>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml"/>
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
        <Style Selector="TemplatedControl">
            <Setter Property="FontSize" Value="{DynamicResource AppBaseFontSize}" />
        </Style>
        <Style Selector="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource AppBaseFontSize}" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="{DynamicResource AppPanelBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        </Style>
        <Style Selector="ComboBox /template/ TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        </Style>
        <Style Selector="ComboBox /template/ TextBox">
            <Setter Property="Background" Value="{DynamicResource TextControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource TextControlForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TextControlBorderBrush}" />
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource AppPanelBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        </Style>
        <Style Selector="ComboBoxItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppButtonNormalBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Style>
        <Style Selector="ComboBoxItem:selected">
            <Setter Property="Background" Value="{DynamicResource AppButtonNormalBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Style>
        <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Style>
        <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource TextControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource TextControlForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TextControlBorderBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextControlForeground}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource TextControlSelectionBrush}" />
            <Setter Property="SelectionForegroundBrush" Value="{DynamicResource TextControlSelectionForegroundBrush}" />
        </Style>
        <Style Selector="TextBox:pointerover">
            <Setter Property="Background" Value="{DynamicResource TextControlBackgroundPointerOver}" />
            <Setter Property="Foreground" Value="{DynamicResource TextControlForegroundPointerOver}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TextControlBorderBrushPointerOver}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextControlForegroundPointerOver}" />
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="Background" Value="{DynamicResource ActiveControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource ActiveControlForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ActiveControlBorderBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource ActiveControlForegroundBrush}" />
        </Style>
        <Style Selector="TextBox:focus-within">
            <Setter Property="Background" Value="{DynamicResource ActiveControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource ActiveControlForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ActiveControlBorderBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource ActiveControlForegroundBrush}" />
        </Style>
        <Style Selector="TextBox /template/ TextPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource TextControlForeground}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource TextControlSelectionBrush}" />
            <Setter Property="SelectionForegroundBrush" Value="{DynamicResource TextControlSelectionForegroundBrush}" />
        </Style>
        <Style Selector="TextBox:focus-within /template/ TextPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource TextControlForegroundFocused}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource TextControlSelectionBrush}" />
            <Setter Property="SelectionForegroundBrush" Value="{DynamicResource TextControlSelectionForegroundBrush}" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Background" Value="{DynamicResource AppHeaderBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Background" Value="{DynamicResource ActiveControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource ActiveControlForegroundBrush}" />
        </Style>
        <Style Selector="TabItem:pointerover:not(:selected)">
            <Setter Property="Background" Value="{DynamicResource ActiveControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource ActiveControlForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ActiveControlBorderBrush}" />
        </Style>
        <Style Selector="TabStripItem">
            <Setter Property="Background" Value="{DynamicResource AppHeaderBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
        <Style Selector="TabStripItem:selected">
            <Setter Property="Background" Value="{DynamicResource AppButtonNormalBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Style>
        <Style Selector="TabStripItem:pointerover:not(:selected)">
            <Setter Property="Background" Value="{DynamicResource AppButtonNormalBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Style>
        <Style Selector="TabStripItem:pointerover:not(:selected) /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Style>
        <Style Selector="TabStripItem:selected /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Style>
        <Style Selector="TabItem:pointerover:not(:selected) /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Style>
        <Style Selector="TabItem:selected /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="Opacity" Value="1" />
        </Style>
    </Application.Styles>
</Application>
