<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HamBusLog.App"
             xmlns:local="using:HamBusLog"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="AppPanelBackgroundBrush" Color="#2C3E50" />
        <SolidColorBrush x:Key="AppHeaderBackgroundBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="AppMenuBackgroundBrush" Color="#111827" />
        <SolidColorBrush x:Key="AppMenuForegroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AppForegroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AppMutedForegroundBrush" Color="#9CA3AF" />
        <SolidColorBrush x:Key="nBrush" Color="#9CA3AF" />
        <SolidColorBrush x:Key="AppBorderBrush" Color="#34495E" />
        <SolidColorBrush x:Key="AppAccentBrush" Color="#3498DB" />
        <SolidColorBrush x:Key="AppButtonNormalBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="AppButtonNormalForegroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AppButtonCautionBrush" Color="#D97706" />
        <SolidColorBrush x:Key="AppButtonCautionForegroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AppButtonDangerBrush" Color="#DC2626" />
        <SolidColorBrush x:Key="AppButtonDangerForegroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AppButtonForegroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AppErrorBrush" Color="#FF6B6B" />
        <SolidColorBrush x:Key="AppWarningBrush" Color="#FFD700" />

        <!-- Fluent text-input palette overrides for high contrast across normal/focus/selection states -->
        <SolidColorBrush x:Key="TextControlBackground" Color="#2C3E50" />
        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#34495E" />
        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#2C3E50" />
        <SolidColorBrush x:Key="TextControlForeground" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextControlBorderBrush" Color="#34495E" />
        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#3498DB" />
        <Color x:Key="TextControlSelectionHighlightColor">#2C3E50</Color>
        <Color x:Key="TextControlSelectionHighlightColorWhenNotFocused">#2C3E50</Color>
    </Application.Resources>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml"/>
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="{DynamicResource AppPanelBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        </Style>
        <Style Selector="ComboBox /template/ TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        </Style>
        <Style Selector="ComboBox /template/ TextBox">
            <Setter Property="Background" Value="{DynamicResource AppPanelBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource AppPanelBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        </Style>
        <Style Selector="ComboBoxItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppButtonNormalBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Style>
        <Style Selector="ComboBoxItem:selected">
            <Setter Property="Background" Value="{DynamicResource AppButtonNormalBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Style>
        <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Style>
        <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource AppPanelBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource AppForegroundBrush}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource AppPanelBackgroundBrush}" />
            <Setter Property="SelectionForegroundBrush" Value="{DynamicResource AppForegroundBrush}" />
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="Background" Value="{DynamicResource AppPanelBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource AppForegroundBrush}" />
        </Style>
        <Style Selector="TextBox:focus-within">
            <Setter Property="Background" Value="{DynamicResource AppPanelBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource AppForegroundBrush}" />
        </Style>
        <Style Selector="TextBox /template/ TextPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AppForegroundBrush}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource AppPanelBackgroundBrush}" />
            <Setter Property="SelectionForegroundBrush" Value="{DynamicResource AppForegroundBrush}" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Background" Value="{DynamicResource AppHeaderBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Background" Value="{DynamicResource AppButtonNormalBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Style>
        <Style Selector="TabItem:pointerover:not(:selected)">
            <Setter Property="Background" Value="{DynamicResource AppButtonNormalBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Style>
        <Style Selector="TabStripItem">
            <Setter Property="Background" Value="{DynamicResource AppHeaderBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
        <Style Selector="TabStripItem:selected">
            <Setter Property="Background" Value="{DynamicResource AppButtonNormalBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Style>
        <Style Selector="TabStripItem:pointerover:not(:selected)">
            <Setter Property="Background" Value="{DynamicResource AppButtonNormalBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Style>
        <Style Selector="TabStripItem:pointerover:not(:selected) /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Style>
        <Style Selector="TabStripItem:selected /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Style>
        <Style Selector="TabItem:pointerover:not(:selected) /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Style>
        <Style Selector="TabItem:selected /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AppButtonNormalForegroundBrush}" />
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="Opacity" Value="1" />
        </Style>
    </Application.Styles>
</Application>
